<%
  const sweeparrMode = String(locals.sweeparrMode || 'overview').trim().toLowerCase() === 'settings'
    ? 'settings'
    : 'overview';
  const isSweeparrSettingsMode = sweeparrMode === 'settings';
  const sweeparrTitle = isSweeparrSettingsMode
    ? 'Rule settings'
    : 'Sweep overview';
  const sweeparrDescription = isSweeparrSettingsMode
    ? 'Adjust cadence, behavior, and removal rules without leaving Launcharr.'
    : 'Monitor queue health, recent sweeps, and flagged removals.';
  const sweeparrSwitchHref = isSweeparrSettingsMode
    ? '/apps/sweeparr'
    : '/apps/sweeparr/settings';
  const sweeparrSwitchLabel = isSweeparrSettingsMode
    ? 'Overview'
    : 'Settings';
  const sweeparrFrameTitle = isSweeparrSettingsMode
    ? 'Embedded Sweeparr settings'
    : 'Embedded Sweeparr overview';
  const sweeparrFrameSrc = `/sweeparr?embed=1&mode=${encodeURIComponent(sweeparrMode)}&v=${encodeURIComponent(String(assetVersion || 'dev'))}&cb=${Date.now()}`;
  const sweeparrMinHeight = isSweeparrSettingsMode ? 1120 : 0;
%>
<section
  class="dash-panel embedded-module-panel embedded-module-panel--sweeparr"
  data-embedded-module-root
  data-module-id="sweeparr"
  data-module-mode="<%= sweeparrMode %>"
>
  <div class="embedded-module-hero">
    <div class="embedded-module-copy">
      <div class="embedded-module-eyebrow">Sweeparr</div>
      <h2 class="embedded-module-title"><%= sweeparrTitle %></h2>
      <p class="embedded-module-description"><%= sweeparrDescription %></p>
    </div>
    <div class="embedded-module-actions">
      <a class="primary-button embedded-module-action" href="<%= sweeparrSwitchHref %>"><%= sweeparrSwitchLabel %></a>
    </div>
  </div>

  <div class="embedded-module-frame-wrap">
    <iframe
      class="embedded-module-frame embedded-module-frame--sweeparr"
      src="<%= sweeparrFrameSrc %>"
      title="<%= sweeparrFrameTitle %>"
      loading="eager"
      scrolling="<%= isSweeparrSettingsMode ? 'yes' : 'no' %>"
      data-module-frame
      data-module-id="sweeparr"
      data-module-mode="<%= sweeparrMode %>"
      data-module-min-height="<%= sweeparrMinHeight %>"
    ></iframe>
  </div>
</section>
<script>
  (function () {
    const root = document.querySelector('[data-embedded-module-root][data-module-id="sweeparr"]');
    if (!root) return;
    const frame = root.querySelector('[data-module-frame][data-module-id="sweeparr"]');
    if (!frame || frame.dataset.embeddedModuleBound === '1') return;
    frame.dataset.embeddedModuleBound = '1';
    const moduleMode = String(frame.dataset.moduleMode || 'overview').trim().toLowerCase();
    const autoResizeEnabled = moduleMode !== 'settings';

    const minHeight = moduleMode === 'settings'
      ? Math.max(480, Number(frame.dataset.moduleMinHeight) || 0)
      : Math.max(0, Number(frame.dataset.moduleMinHeight) || 0);
    const applyFrameHeight = (value) => {
      const nextHeight = Math.max(minHeight, Math.ceil(Number(value) || 0));
      frame.style.height = `${nextHeight}px`;
    };
    const requestHeight = () => {
      if (!frame.contentWindow) return;
      try {
        frame.contentWindow.postMessage({ type: 'sweeparr:request-height' }, '*');
      } catch (_err) {
        return;
      }
    };

    applyFrameHeight(minHeight);
    if (!autoResizeEnabled) return;

    window.addEventListener('message', (event) => {
      if (event.source !== frame.contentWindow) return;
      const data = event && event.data && typeof event.data === 'object' ? event.data : null;
      if (!data || String(data.type || '') !== 'sweeparr:height') return;
      applyFrameHeight(data.height);
    });

    frame.addEventListener('load', () => {
      requestHeight();
      window.setTimeout(requestHeight, 80);
      window.setTimeout(requestHeight, 240);
      window.setTimeout(requestHeight, 600);
    });

    window.addEventListener('resize', requestHeight);
    requestHeight();
  }());
</script>
