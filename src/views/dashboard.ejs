<%- include('partials/head', { pageTitle: title || 'Dashboard — Curatorr', extraCss: extraCss || ['/styles-layout.css', '/styles-curatorr.css'] }) %>
<body class="dash-body">
  <div class="dash-frame">
    <aside class="dash-sidebar">
      <div class="dash-brand">
        <span class="dash-logo">
          <img class="nav-icon" src="/icons/curatorr-icon.svg" alt="Curatorr" onerror="this.style.display='none'" />
        </span>
        <div>
          <div class="dash-title">Curatorr</div>
        </div>
      </div>

      <div class="dash-nav">
        <%- include('partials/nav-categories', { navActivePage: 'dashboard', role: role }) %>
      </div>

      <%- include('partials/user-menu') %>
    </aside>

    <section class="dash-main">
      <div id="cur-page-bg" class="cur-page-bg"></div>
      <div class="main-window-bar">
        <button class="sidebar-toggle main-toggle left-toggle" type="button" aria-label="Toggle sidebar">
          <img class="toggle-icon" src="/icons/sidebar-toggle.svg" alt="" />
        </button>
        <div class="main-window-title">
          <img class="main-window-icon" src="/icons/dashboard.svg" alt="" />
          <span class="main-window-app">Curatorr</span>
          <span class="main-window-rest">| Dashboard</span>
        </div>
        <div class="main-window-spacer"></div>
        <div class="main-window-status">
          <span class="status-dot"></span>
        </div>
      </div>

      <div class="dash-content">
        <%
          const _stats7d = stats7d || { plays: 0, skips: 0, skipRate: 0 };
          const _stats30d = stats30d || { plays: 0, skips: 0, skipRate: 0 };
          const _byDay = Array.isArray(byDay) ? byDay : [];
          const _topArtists = Array.isArray(topArtists) ? topArtists : [];
          const _topTracks = Array.isArray(topTracks) ? topTracks : [];
          const _recentHistory = Array.isArray(recentHistory) ? recentHistory : [];
          const _maxPlays = _byDay.reduce((m, d) => Math.max(m, d.plays || 0), 1);

          function fmtTime(ms) {
            if (!ms) return '—';
            const s = Math.floor(ms / 1000);
            const m = Math.floor(s / 60);
            const h = Math.floor(m / 60);
            if (h) return h + 'h ' + (m % 60) + 'm';
            if (m) return m + 'm ' + (s % 60) + 's';
            return s + 's';
          }
          function fmtDate(ts) {
            if (!ts) return '—';
            return new Date(ts).toLocaleString([], { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
          }
        %>

        <%# ── Stat cards ─────────────────────────────────────────────────── %>
        <div class="cur-stat-row">
          <div class="cur-stat-card">
            <div class="cur-stat-label">Plays (7d)</div>
            <div class="cur-stat-value"><%= _stats7d.plays %></div>
          </div>
          <div class="cur-stat-card cur-stat-card--skip">
            <div class="cur-stat-label">Skips (7d)</div>
            <div class="cur-stat-value"><%= _stats7d.skips %></div>
          </div>
          <div class="cur-stat-card">
            <div class="cur-stat-label">Skip rate (7d)</div>
            <div class="cur-stat-value"><%= _stats7d.plays ? Math.round(_stats7d.skipRate * 100) : 0 %>%</div>
          </div>
          <div class="cur-stat-card">
            <div class="cur-stat-label">Plays (30d)</div>
            <div class="cur-stat-value"><%= _stats30d.plays %></div>
          </div>
          <div class="cur-stat-card cur-stat-card--skip">
            <div class="cur-stat-label">Skips (30d)</div>
            <div class="cur-stat-value"><%= _stats30d.skips %></div>
          </div>
          <div class="cur-stat-card">
            <div class="cur-stat-label">Skip rate (30d)</div>
            <div class="cur-stat-value"><%= _stats30d.plays ? Math.round(_stats30d.skipRate * 100) : 0 %>%</div>
          </div>
        </div>

        <%# ── Active streams + Activity chart side by side ──────────────── %>
        <div class="cur-two-col cur-two-col--streams-chart">
        <div class="cur-panel cur-panel--streams" id="cur-streams-panel">
          <div class="cur-panel-header">
            <h3 class="cur-panel-title">
              <span class="cur-stream-dot" id="cur-stream-dot"></span>
              Now playing
            </h3>
            <span class="cur-streams-count" id="cur-streams-count" style="display:none"></span>
          </div>
          <div id="cur-streams-body" class="cur-streams-body">
            <div class="cur-empty cur-streams-empty">No music playing right now.</div>
          </div>
        </div>

        <%# ── Activity chart ──────────────────────────────────────────────── %>
        <div class="cur-panel">
          <div class="cur-panel-header">
            <h3 class="cur-panel-title">Plays last 14 days</h3>
          </div>
          <div class="cur-bar-chart">
            <% _byDay.forEach(function(day) { %>
              <%
                const barPct = _maxPlays > 0 ? Math.round((day.plays / _maxPlays) * 100) : 0;
                const skipPct = day.plays > 0 ? Math.round((day.skips / day.plays) * 100) : 0;
              %>
              <div class="cur-bar-col" title="<%= day.label %>: <%= day.plays %> plays, <%= day.skips %> skips">
                <div class="cur-bar-wrap">
                  <div class="cur-bar" style="height:<%= barPct %>%">
                    <% if (day.skips > 0) { %>
                      <div class="cur-bar-skip" style="height:<%= skipPct %>%"></div>
                    <% } %>
                  </div>
                </div>
                <div class="cur-bar-label"><%= day.label %></div>
              </div>
            <% }) %>
            <% if (!_byDay.length) { %>
              <div class="cur-empty">No play data yet. Plays will appear here once Tautulli or Plex webhooks start sending events.</div>
            <% } %>
          </div>
        </div>
        </div><%# end cur-two-col--streams-chart %>

        <div class="cur-two-col">
          <%# ── Top artists ──────────────────────────────────────────────── %>
          <div class="cur-panel">
            <div class="cur-panel-header">
              <h3 class="cur-panel-title">Top artists (30d)</h3>
              <a href="/artists" class="cur-panel-link">View all</a>
            </div>
            <% if (_topArtists.length) { %>
              <ul class="cur-list">
                <% _topArtists.forEach(function(a) { %>
                  <li class="cur-list-item">
                    <span class="cur-list-name"><%= a.artist_name %></span>
                    <span class="cur-list-meta"><%= a.total_plays %> plays</span>
                    <% if (a.excluded) { %><span class="cur-badge cur-badge--skip">excluded</span><% } %>
                    <% if (a.skip_streak > 0) { %><span class="cur-badge cur-badge--warn"><%= a.skip_streak %> skips</span><% } %>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <div class="cur-empty">No artist data yet.</div>
            <% } %>
          </div>

          <%# ── Top tracks ───────────────────────────────────────────────── %>
          <div class="cur-panel">
            <div class="cur-panel-header">
              <h3 class="cur-panel-title">Top tracks (30d)</h3>
              <a href="/tracks" class="cur-panel-link">View all</a>
            </div>
            <% if (_topTracks.length) { %>
              <ul class="cur-list">
                <% _topTracks.forEach(function(t) { %>
                  <li class="cur-list-item">
                    <div class="cur-list-primary">
                      <span class="cur-list-name"><%= t.track_title %></span>
                      <span class="cur-list-sub"><%= t.artist_name %></span>
                    </div>
                    <span class="cur-list-meta"><%= t.total_plays %> plays</span>
                    <% if (t.excluded) { %><span class="cur-badge cur-badge--skip">excluded</span><% } %>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <div class="cur-empty">No track data yet.</div>
            <% } %>
          </div>
        </div>

        <%# ── Recent history ──────────────────────────────────────────────── %>
        <div class="cur-panel">
          <div class="cur-panel-header">
            <h3 class="cur-panel-title">Recent plays</h3>
            <a href="/history" class="cur-panel-link">View all</a>
          </div>
          <% if (_recentHistory.length) { %>
            <div class="cur-history-table">
              <div class="cur-history-head">
                <span>Track</span>
                <span>Artist</span>
                <span>Listened</span>
                <span>When</span>
              </div>
              <% _recentHistory.forEach(function(h) { %>
                <div class="cur-history-row<%= h.is_skip ? ' cur-history-row--skip' : '' %>">
                  <span class="cur-history-track"><%= h.track_title || '—' %><% if (h.is_skip) { %> <span class="cur-badge cur-badge--skip">skip</span><% } %></span>
                  <span class="cur-history-artist"><%= h.artist_name || '—' %></span>
                  <span class="cur-history-dur"><%= fmtTime(h.duration_ms) %></span>
                  <span class="cur-history-when"><%= fmtDate(h.started_at) %></span>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="cur-empty">No play history yet. Configure Tautulli or Plex webhooks to start tracking.</div>
          <% } %>
        </div>

        <%# ── Playlist sync status ────────────────────────────────────────── %>
        <% if (lastSync) { %>
          <div class="cur-panel cur-panel--sync">
            <div class="cur-panel-header">
              <h3 class="cur-panel-title">Last playlist sync</h3>
              <a href="/playlists" class="cur-panel-link">Manage</a>
            </div>
            <div class="cur-sync-info">
              <span class="cur-sync-playlist"><%= lastSync.playlist_title || 'Smart Mix' %></span>
              <span class="cur-sync-meta"><%= lastSync.track_count %> tracks · <%= lastSync.excluded_tracks %> tracks excluded · <%= lastSync.excluded_artists %> artists excluded</span>
              <span class="cur-sync-when">Synced <%= fmtDate(lastSync.synced_at) %></span>
            </div>
          </div>
        <% } %>
      </div>
    </section>
  </div>

  <script src="/sidebar.js?v=<%= assetVersion %>"></script>
  <script src="/user-menu.js?v=<%= assetVersion %>"></script>
  <script>
  (function() {
    var body   = document.getElementById('cur-streams-body');
    var dot    = document.getElementById('cur-stream-dot');
    var cnt    = document.getElementById('cur-streams-count');
    var pageBg = document.getElementById('cur-page-bg');

    function fmtMs(ms) {
      if (!ms) return '0:00';
      var s = Math.floor(ms / 1000), m = Math.floor(s / 60);
      return m + ':' + String(s % 60).padStart(2, '0');
    }
    function pct(offset, dur) {
      return dur > 0 ? Math.min(100, Math.round(offset / dur * 100)) : 0;
    }

    function artUrl(path) {
      return path ? '/api/plex/art?path=' + encodeURIComponent(path) : '';
    }

    function render(sessions) {
      dot.className = 'cur-stream-dot' + (sessions.length ? ' cur-stream-dot--live' : '');
      if (sessions.length) {
        cnt.style.display = '';
        cnt.textContent = sessions.length + ' stream' + (sessions.length > 1 ? 's' : '');
      } else {
        cnt.style.display = 'none';
      }

      // Full-page background from first active stream's art
      var first = sessions.find(function(s){ return s.state !== 'paused'; }) || sessions[0];
      var bgSrc = first ? artUrl(first.artistThumb || first.albumThumb) : '';
      if (bgSrc) {
        pageBg.style.backgroundImage = 'url(' + bgSrc + ')';
        pageBg.classList.add('is-active');
      } else {
        pageBg.classList.remove('is-active');
      }

      if (!sessions.length) {
        body.innerHTML = '<div class="cur-empty cur-streams-empty">No music playing right now.</div>';
        return;
      }
      body.innerHTML = sessions.map(function(s) {
        var p = pct(s.viewOffset, s.duration);
        var isPaused = s.state === 'paused';
        var stateLabel = isPaused ? '⏸ Paused' : '▶ Playing';
        var albumImg = artUrl(s.albumThumb || s.artistThumb);
        return '<div class="cur-stream-row' + (isPaused ? ' cur-stream-row--paused' : '') + '">' +
          '<div class="cur-stream-content">' +
            (albumImg
              ? '<img class="cur-stream-album-art" src="' + escAttr(albumImg) + '" alt="" loading="lazy" />'
              : '<div class="cur-stream-album-art cur-stream-album-art--empty"></div>') +
            '<div class="cur-stream-details">' +
              '<div class="cur-stream-track">' + escHtml(s.title) + '</div>' +
              '<div class="cur-stream-meta">' + escHtml(s.artist) +
                (s.album ? '<span class="cur-stream-album-sep"> · </span>' + escHtml(s.album) : '') + '</div>' +
              '<div class="cur-stream-footer">' +
                '<span class="cur-stream-user">' + escHtml(s.userName || 'Unknown') + '</span>' +
                '<span class="cur-stream-device">' + escHtml(s.playerTitle || '') + '</span>' +
                '<span class="cur-stream-state ' + (isPaused ? 'cur-stream-state--paused' : '') + '">' + stateLabel + '</span>' +
                '<span class="cur-stream-time">' + fmtMs(s.viewOffset) + ' / ' + fmtMs(s.duration) + '</span>' +
              '</div>' +
              '<div class="cur-stream-progress"><div class="cur-stream-bar" style="width:' + p + '%"></div></div>' +
            '</div>' +
          '</div>' +
        '</div>';
      }).join('');
    }

    function escHtml(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function escAttr(s) {
      return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;');
    }

    function poll() {
      fetch('/api/plex/sessions')
        .then(function(r){ return r.json(); })
        .then(function(d){ if (d.ok) render(d.sessions); })
        .catch(function(){});
    }

    poll();
    setInterval(poll, 12000);
  })();
  </script>
</body>
</html>
