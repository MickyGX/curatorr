<%- include('partials/head', { pageTitle: title || 'My Settings — Curatorr', extraCss: extraCss || ['/styles-layout.css', '/styles-settings.css'] }) %>
<body class="dash-body">
  <div class="dash-frame">
    <aside class="dash-sidebar">
      <div class="dash-brand">
        <span class="dash-logo">
          <img class="nav-icon" src="/icons/curatorr-icon.svg" alt="Curatorr" onerror="this.style.display='none'" />
        </span>
        <div><div class="dash-title">Curatorr</div></div>
      </div>
      <div class="dash-nav">
        <%- include('partials/nav-categories', { navActivePage: '', role: role }) %>
      </div>
      <%- include('partials/user-menu') %>
    </aside>

    <section class="dash-main">
      <div class="main-window-bar">
        <button class="sidebar-toggle main-toggle left-toggle" type="button" aria-label="Toggle sidebar">
          <img class="toggle-icon" src="/icons/sidebar-toggle.svg" alt="" />
        </button>
        <div class="main-window-title">
          <img class="main-window-icon" src="/icons/user-profile.svg" alt="" />
          <span class="main-window-app">Curatorr</span>
          <span class="main-window-rest">| My Profile</span>
        </div>
        <div class="main-window-spacer"></div>
      </div>

      <div class="dash-content">
        <% if (success) { %>
          <div class="settings-success">
            <% if (success === 'password-changed') { %>Password changed successfully.<% } else if (success === 'avatar-updated') { %>Avatar updated.<% } else if (success === 'theme-updated') { %>Theme saved.<% } else { %>Saved.<% } %>
          </div>
        <% } %>
        <% if (error) { %>
          <div class="settings-error"><%= error %></div>
        <% } %>

        <div class="settings-layout">
          <div class="settings-panels">

            <%# ── Avatar ──────────────────────────────────────────────── %>
            <div class="settings-panel">
              <h2 class="settings-panel-title">Avatar</h2>
              <div class="settings-avatar-wrap">
                <img class="settings-avatar-preview" id="avatarPreview"
                  src="<%= user.avatar || user.avatarFallback || '/icons/user-profile.svg' %>"
                  alt="Your avatar" onerror="this.src='/icons/user-profile.svg'" />
                <div class="settings-avatar-controls">
                  <label class="btn btn-secondary" for="avatarFile">Choose image</label>
                  <input type="file" id="avatarFile" accept="image/*" style="display:none" onchange="previewAvatar(this)" />
                  <form method="post" action="/user-settings/avatar" id="avatarForm">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <input type="hidden" name="avatarData" id="avatarData" />
                    <button type="submit" id="avatarSaveBtn" class="btn btn-primary" style="display:none">Save avatar</button>
                  </form>
                </div>
              </div>
            </div>

            <%# ── Change password (local auth only) ──────────────────── %>
            <% if (String(user.source || '').toLowerCase() === 'local') { %>
              <div class="settings-panel">
                <h2 class="settings-panel-title">Change password</h2>
                <form method="post" action="/user-settings/password" class="settings-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <div class="settings-field">
                    <label class="settings-label" for="currentPassword">Current password</label>
                    <input class="settings-input" type="password" id="currentPassword" name="currentPassword" required autocomplete="current-password" />
                  </div>
                  <div class="settings-field">
                    <label class="settings-label" for="newPassword">New password</label>
                    <input class="settings-input" type="password" id="newPassword" name="newPassword" required autocomplete="new-password" />
                  </div>
                  <div class="settings-field">
                    <label class="settings-label" for="confirmPassword">Confirm new password</label>
                    <input class="settings-input" type="password" id="confirmPassword" name="confirmPassword" required autocomplete="new-password" />
                  </div>
                  <div class="settings-actions">
                    <button type="submit" class="btn btn-primary">Change password</button>
                  </div>
                </form>
              </div>
            <% } %>

            <%# ── Theme ───────────────────────────────────────────────── %>
            <div class="settings-panel">
              <h2 class="settings-panel-title">Theme</h2>
              <form method="post" action="/user-settings/theme" class="settings-form" id="themeForm">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <div class="settings-field">
                  <label class="settings-label">Color mode</label>
                  <div class="settings-radio-group">
                    <label class="settings-radio">
                      <input type="radio" name="mode" value="night" <%= (config.theme?.mode !== 'day') ? 'checked' : '' %> />
                      <span>Night</span>
                    </label>
                    <label class="settings-radio">
                      <input type="radio" name="mode" value="day" <%= (config.theme?.mode === 'day') ? 'checked' : '' %> />
                      <span>Day</span>
                    </label>
                  </div>
                </div>
                <div class="settings-actions">
                  <button type="submit" class="btn btn-primary">Save theme</button>
                </div>
              </form>
            </div>

          </div>
        </div>
      </div>
    </section>
  </div>

  <script src="/sidebar.js?v=<%= assetVersion %>"></script>
  <script src="/user-menu.js?v=<%= assetVersion %>"></script>
  <script>
    function previewAvatar(input) {
      if (!input.files || !input.files[0]) return;
      const reader = new FileReader();
      reader.onload = function(e) {
        document.getElementById('avatarPreview').src = e.target.result;
        document.getElementById('avatarData').value = e.target.result;
        document.getElementById('avatarSaveBtn').style.display = '';
      };
      reader.readAsDataURL(input.files[0]);
    }
  </script>
</body>
</html>
