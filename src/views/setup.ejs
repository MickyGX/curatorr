<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Curatorr · Create admin</title>
  <%- include('partials/theme-init') %>
  <link rel="stylesheet" href="/styles.css?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="/styles-auth.css?v=<%= assetVersion %>" />
  <link rel="icon" type="image/svg+xml" href="/icons/curatorr-icon.svg" />
  <meta name="theme-color" content="#8b5cf6" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
</head>
<body class="login-body">
  <div class="login-stars"></div>
  <div class="login-planet"></div>

  <main class="login-wrap">
    <div class="login-hero">
      <div class="login-brand">
        <span class="login-brand-mark">
          <img src="/icons/curatorr-icon.svg" alt="Curatorr" onerror="this.style.display='none'" />
        </span>
        <div class="login-brand-title">Curatorr</div>
        <div class="login-brand-subtitle">Smart playlist curator</div>
      </div>
      <div class="login-card">
        <div class="login-card-title">Create admin</div>
        <div class="login-card-sub">Finish setup to unlock your dashboard</div>
        <% if (error) { %>
          <div class="login-error"><%= error %></div>
        <% } %>
        <form class="login-form" method="post" action="/setup">
          <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>" />
          <label class="login-field">
            <span>Username</span>
            <input class="login-input" type="text" name="username" value="<%= values?.username || '' %>" autocomplete="username" required />
          </label>
          <label class="login-field">
            <span>Email</span>
            <input class="login-input" type="email" name="email" value="<%= values?.email || '' %>" autocomplete="email" required />
          </label>
          <label class="login-field">
            <span>Password (min <%= minPassword %>, upper/lower/number/symbol)</span>
            <input class="login-input" type="password" name="password" autocomplete="new-password" required />
          </label>
          <label class="login-field">
            <span>Confirm password</span>
            <input class="login-input" type="password" name="confirmPassword" autocomplete="new-password" required />
          </label>
          <button class="primary-button" type="submit">Create admin</button>
        </form>
        <div class="login-sub">You can also sign in with Plex SSO after setup.</div>
      </div>
    </div>
  </main>
  <script src="/starfield-3d.js"></script>
</body>
</html>
