<%- include('partials/head', { pageTitle: title || 'Settings — Curatorr', extraCss: extraCss || ['/styles-layout.css', '/styles-settings.css'] }) %>
<body class="dash-body">
  <div class="dash-frame">
    <aside class="dash-sidebar">
      <div class="dash-brand">
        <span class="dash-logo">
          <img class="nav-icon" src="/icons/curatorr-icon.svg" alt="Curatorr" onerror="this.style.display='none'" />
        </span>
        <div><div class="dash-title">Curatorr</div></div>
      </div>
      <div class="dash-nav">
        <%- include('partials/nav-categories', { navActivePage: 'settings', role: role }) %>
      </div>
      <%- include('partials/user-menu') %>
    </aside>

    <section class="dash-main">
      <div class="main-window-bar">
        <button class="sidebar-toggle main-toggle left-toggle" type="button" aria-label="Toggle sidebar">
          <img class="toggle-icon" src="/icons/sidebar-toggle.svg" alt="" />
        </button>
        <div class="main-window-title">
          <img class="main-window-icon" src="/icons/settings.svg" alt="" />
          <span class="main-window-app">Curatorr</span>
          <span class="main-window-rest">| Settings</span>
        </div>
        <div class="main-window-spacer"></div>
      </div>

      <div class="dash-content">
        <% const _tab = tab || 'general'; %>

        <% if (success) { %>
          <div class="settings-debug" style="border-color:rgba(74,222,128,.35);background:rgba(74,222,128,.1);color:#4ade80;margin-bottom:0">Settings saved successfully.</div>
        <% } %>
        <% if (error) { %>
          <div class="settings-debug" style="margin-bottom:0"><%= error %></div>
        <% } %>

        <div class="settings-tabs" role="tablist" aria-label="Settings tabs">
          <button class="settings-tab-btn" type="button" data-tab="general">
            <img class="settings-tab-icon" src="/icons/settings.svg" alt="" />
            <span class="settings-tab-text">General</span>
          </button>
          <button class="settings-tab-btn" type="button" data-tab="plex">
            <img class="settings-tab-icon" src="/icons/plex.svg" alt="" />
            <span class="settings-tab-text">Plex</span>
          </button>
          <button class="settings-tab-btn" type="button" data-tab="tautulli">
            <img class="settings-tab-icon" src="/icons/tautulli.svg" alt="" />
            <span class="settings-tab-text">Tautulli</span>
          </button>
          <button class="settings-tab-btn" type="button" data-tab="lidarr">
            <img class="settings-tab-icon" src="/icons/lidarr.svg" alt="" />
            <span class="settings-tab-text">Lidarr</span>
          </button>
          <button class="settings-tab-btn" type="button" data-tab="smart-playlist">
            <img class="settings-tab-icon" src="/icons/music.svg" alt="" />
            <span class="settings-tab-text">Smart Playlist</span>
          </button>
          <button class="settings-tab-btn" type="button" data-tab="filters">
            <img class="settings-tab-icon" src="/icons/tools.svg" alt="" />
            <span class="settings-tab-text">Filters</span>
          </button>
          <button class="settings-tab-btn" type="button" data-tab="users">
            <img class="settings-tab-icon" src="/icons/user-profile.svg" alt="" />
            <span class="settings-tab-text">Users</span>
          </button>
          <button class="settings-tab-btn" type="button" data-tab="appearance">
            <img class="settings-tab-icon" src="/icons/sun.svg" alt="" />
            <span class="settings-tab-text">Appearance</span>
          </button>
        </div>

        <%# ── General ──────────────────────────────────────────────────────── %>
        <div class="settings-tab-panel" data-tab="general">
          <div class="dash-panel">
            <form method="post" action="/settings/general" class="settings-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div class="settings-card">
                <div class="settings-card-title">Server Identity</div>
                <div class="settings-card-sub">Remote URL is used for external links and webhook callbacks. Local URL is preferred for LAN Plex SSO. Use Base URL Path when Curatorr is served behind a subpath (for example <code style="background:rgba(255,255,255,.08);padding:2px 6px;border-radius:5px;font-size:11px">/curatorr</code>).</div>
                <label class="field">
                  <span>Server name</span>
                  <input type="text" name="serverName" value="<%= config.general?.serverName || 'Curatorr' %>" placeholder="Curatorr" />
                </label>
                <label class="field">
                  <span>Remote URL</span>
                  <input type="text" name="remoteUrl" value="<%= config.general?.remoteUrl || '' %>" placeholder="https://curatorr.example.com" />
                </label>
                <label class="field">
                  <span>Local URL</span>
                  <input type="text" name="localUrl" value="<%= config.general?.localUrl || '' %>" placeholder="http://192.168.0.x:7676" />
                </label>
                <label class="field">
                  <span>Base URL Path</span>
                  <input type="text" name="basePath" value="<%= config.general?.basePath || '' %>" placeholder="/curatorr" />
                </label>
                <label class="settings-toggle" style="margin-top:4px">
                  <input type="checkbox" name="restrictGuests" value="1" <%= config.general?.restrictGuests ? 'checked' : '' %> />
                  <span class="settings-toggle-slider" aria-hidden="true"></span>
                  <span class="settings-toggle-text">Restrict guest users</span>
                </label>
              </div>
              <button class="primary-button" type="submit">Save general settings</button>
            </form>
          </div>
        </div>

        <%# ── Plex ─────────────────────────────────────────────────────────── %>
        <div class="settings-tab-panel" data-tab="plex">
          <div class="dash-panel">
            <form method="post" action="/settings/plex" class="settings-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div class="settings-card">
                <div class="settings-card-title">App URLs</div>
                <div class="settings-card-sub">Local URL is used inside your network. Remote URL is used for external access. Local URL is preferred when set.</div>
                <label class="field">
                  <span>Local URL</span>
                  <input type="text" name="plexLocalUrl" value="<%= config.plex?.localUrl || config.plex?.url || '' %>" placeholder="http://192.168.1.x:32400" />
                </label>
                <label class="field">
                  <span>Remote URL</span>
                  <input type="text" name="plexRemoteUrl" value="<%= config.plex?.remoteUrl || '' %>" placeholder="https://plex.example.com" />
                </label>
              </div>
              <div class="settings-card plex-settings-card">
                <div class="settings-card-title">Plex Access</div>
                <div class="settings-card-sub">Uses the Local URL first, then the Remote URL.</div>
                <div class="plex-settings-fields">
                  <label class="field field-with-action">
                    <span>Plex Token</span>
                    <div class="field-action-row">
                      <input id="plex-token-input" type="password" name="plexToken" value="" placeholder="<%= config.plex?.tokenSet ? '(saved — leave blank to keep)' : 'Enter Plex token' %>" data-plex-field="token" />
                      <button class="icon-button" type="button" aria-label="Show Plex token" data-visibility-toggle="plex-token-input" data-visibility-state="hidden">
                        <img src="/icons/view-off.svg" alt="" />
                      </button>
                    </div>
                  </label>
                  <label class="field field-with-action">
                    <span>Machine ID</span>
                    <div class="field-action-row">
                      <input id="plex-machine-input" type="password" name="machineId" value="<%= config.plex?.machineId || '' %>" placeholder="Plex server machine identifier" data-plex-field="machine" />
                      <button class="icon-button" type="button" aria-label="Show machine ID" data-visibility-toggle="plex-machine-input" data-visibility-state="hidden">
                        <img src="/icons/view-off.svg" alt="" />
                      </button>
                    </div>
                  </label>
                  <label class="field">
                    <span>Plex Admin User</span>
                    <input type="text" name="plexAdminUser" value="<%= config.plex?.adminUser || '' %>" placeholder="admin@plex.tv" />
                  </label>
                  <div class="plex-settings-actions" style="display:flex;gap:8px;margin-top:4px">
                    <button class="ghost-button" type="button" data-plex-action="token">Get Plex Token</button>
                    <button class="ghost-button" type="button" data-plex-action="machine">Get Plex Machine</button>
                  </div>
                </div>
                <div class="plex-settings-note">Tip: Local URL is preferred when set.</div>
              </div>
              <% if (config.plex?.availableLibraries?.length) { %>
              <div class="settings-card">
                <div class="settings-card-title">Music Libraries</div>
                <div class="settings-card-sub">Select which Plex music libraries Curatorr should monitor.</div>
                <div class="settings-checklist" style="display:flex;flex-direction:column;gap:8px">
                  <% config.plex.availableLibraries.forEach(function(lib) { %>
                    <label class="settings-toggle">
                      <input type="checkbox" name="libraries" value="<%= lib.key %>" <%= (config.plex?.libraries || []).includes(lib.key) ? 'checked' : '' %> />
                      <span class="settings-toggle-slider" aria-hidden="true"></span>
                      <span class="settings-toggle-text"><%= lib.title %></span>
                    </label>
                  <% }) %>
                </div>
              </div>
              <% } %>
              <button class="primary-button" type="submit">Save Plex settings</button>
            </form>
          </div>
        </div>

        <%# ── Tautulli ─────────────────────────────────────────────────────── %>
        <div class="settings-tab-panel" data-tab="tautulli">
          <div class="dash-panel">
            <form method="post" action="/settings/tautulli" class="settings-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div class="settings-card">
                <div class="settings-card-title">App URLs</div>
                <div class="settings-card-sub">Local URL is used inside your network. Remote URL is used for external access. Local URL is preferred when set.</div>
                <label class="field">
                  <span>Local URL</span>
                  <input type="text" name="tautulliLocalUrl" value="<%= config.tautulli?.localUrl || config.tautulli?.url || '' %>" placeholder="http://192.168.1.x:8181" />
                </label>
                <label class="field">
                  <span>Remote URL</span>
                  <input type="text" name="tautulliRemoteUrl" value="<%= config.tautulli?.remoteUrl || '' %>" placeholder="https://tautulli.example.com" />
                </label>
              </div>
              <div class="settings-card plex-settings-card">
                <div class="settings-card-title">Tautulli Access</div>
                <div class="settings-card-sub">
                  In Tautulli: Settings → Notification Agents → Webhook<br />
                  URL: <code style="background:rgba(255,255,255,.08);padding:2px 6px;border-radius:5px;font-size:11px"><%= (config.general?.remoteUrl || config.general?.localUrl || 'http://curatorr:7676').replace(/\/$/, '') %>/webhook/tautulli</code><br />
                  Method: POST · Triggers: Playback Start, Stop, Pause, Resume, Watched
                </div>
                <div class="plex-settings-fields">
                  <label class="field field-with-action">
                    <span>API key</span>
                    <div class="field-action-row">
                      <input id="tautulli-apikey-input" type="password" name="apiKey" value="<%= config.tautulli?.apiKey || '' %>" placeholder="Tautulli API key" />
                      <button class="icon-button" type="button" aria-label="Show API key" data-visibility-toggle="tautulli-apikey-input" data-visibility-state="hidden">
                        <img src="/icons/view-off.svg" alt="" />
                      </button>
                    </div>
                  </label>
                </div>
              </div>
              <button class="primary-button" type="submit">Save Tautulli settings</button>
            </form>
          </div>
        </div>

        <%# ── Lidarr ───────────────────────────────────────────────────────── %>
        <div class="settings-tab-panel" data-tab="lidarr">
          <div class="dash-panel">
            <form method="post" action="/settings/lidarr" class="settings-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div class="settings-card">
                <div class="settings-card-title">App URLs</div>
                <div class="settings-card-sub">Local URL is used inside your network. Remote URL is used for external access. Local URL is preferred when set.</div>
                <label class="field">
                  <span>Local URL</span>
                  <input type="text" name="lidarrLocalUrl" value="<%= config.lidarr?.localUrl || config.lidarr?.url || '' %>" placeholder="http://192.168.1.x:8686" />
                </label>
                <label class="field">
                  <span>Remote URL</span>
                  <input type="text" name="lidarrRemoteUrl" value="<%= config.lidarr?.remoteUrl || '' %>" placeholder="https://lidarr.example.com" />
                </label>
              </div>
              <div class="settings-card plex-settings-card">
                <div class="settings-card-title">Lidarr Access</div>
                <div class="settings-card-sub">Connect to Lidarr for music library management. Find the API key in Lidarr → Settings → General.</div>
                <div class="plex-settings-fields">
                  <label class="field field-with-action">
                    <span>API key</span>
                    <div class="field-action-row">
                      <input id="lidarr-apikey-input" type="password" name="apiKey" value="<%= config.lidarr?.apiKey || '' %>" placeholder="Lidarr API key" />
                      <button class="icon-button" type="button" aria-label="Show API key" data-visibility-toggle="lidarr-apikey-input" data-visibility-state="hidden">
                        <img src="/icons/view-off.svg" alt="" />
                      </button>
                    </div>
                  </label>
                </div>
              </div>
              <button class="primary-button" type="submit">Save Lidarr settings</button>
            </form>
          </div>
        </div>

        <%# ── Smart Playlist ───────────────────────────────────────────────── %>
        <div class="settings-tab-panel" data-tab="smart-playlist">
          <div class="dash-panel">
            <form method="post" action="/settings/smart-playlist" class="settings-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div class="settings-card">
                <div class="settings-card-title">Curatorr Rules</div>
                <div class="settings-card-sub">Control how your listening habits affect your smart playlists.</div>
                <%
                  const _skipSec    = config.smartPlaylist?.skipThresholdSeconds      || 30;
                  const _compSec    = config.smartPlaylist?.completionThresholdSeconds || 30;
                  const _songLim    = config.smartPlaylist?.songSkipLimit              || 2;
                  const _skipW   = config.smartPlaylist?.skipWeight   ?? -1;
                  const _belterW = config.smartPlaylist?.belterWeight ?? 1;
                  // Half Decent and Decent are always derived — not user-settable
                  const _hdW     = +(_skipW / 2).toFixed(2);
                  const _decentW = +(_belterW / 2).toFixed(2);
                  const _artistSkipRank = config.smartPlaylist?.artistSkipRank ?? 2;
                  const _artistBelterRank = config.smartPlaylist?.artistBelterRank ?? 8;
                  // Detect which preset (if any) matches the current saved values
                  const _presetDefs = {
                    cautious:   { s:20, c:20, sw:-0.5, bw:0.5,  sr:1, br:9, sl:3 },
                    measured:   { s:30, c:30, sw:-1,   bw:1,    sr:2, br:8, sl:2 },
                    aggressive: { s:40, c:40, sw:-1.5, bw:1.5,  sr:3, br:7, sl:1 },
                  };
                  const _activePreset = Object.keys(_presetDefs).find(k => {
                    const p = _presetDefs[k];
                    return _skipSec === p.s && _compSec === p.c &&
                           _skipW === p.sw && _belterW === p.bw &&
                           _artistSkipRank === p.sr && _artistBelterRank === p.br &&
                           _songLim === p.sl;
                  }) || '';
                %>
                <div style="margin-bottom:14px">
                  <label class="field">
                    <span>Quick preset</span>
                    <select id="curPreset" style="flex:1">
                      <option value="" <%= _activePreset === '' ? 'selected' : '' %>>— Custom —</option>
                      <option value="cautious" <%= _activePreset === 'cautious' ? 'selected' : '' %>>Cautious — larger playlist, wide range of artists</option>
                      <option value="measured" <%= _activePreset === 'measured' ? 'selected' : '' %>>Measured — medium playlist, good mix of artists</option>
                      <option value="aggressive" <%= _activePreset === 'aggressive' ? 'selected' : '' %>>Aggressive — smaller playlist, I know what I like</option>
                    </select>
                  </label>
                  <p id="curPresetDesc" style="font-size:11px;color:var(--muted);margin:4px 0 0;min-height:14px;text-transform:none;letter-spacing:0"></p>
                </div>
                <div class="cur-tier-table-wrap">
                  <table class="cur-tier-table">
                    <colgroup>
                      <col class="cur-tier-col cur-tier-col--label" />
                      <col class="cur-tier-col" />
                      <col class="cur-tier-col" />
                      <col class="cur-tier-col" />
                      <col class="cur-tier-col" />
                    </colgroup>
                    <thead>
                      <tr>
                        <th scope="col">
                          <div class="cur-tier-head-label">
                            <span class="cur-badge cur-badge--curatorr">Curatorr</span>
                          </div>
                        </th>
                        <th scope="col">
                          <div class="cur-tier-head-label">
                            <span class="cur-badge cur-badge--skip">Skip</span>
                          </div>
                        </th>
                        <th scope="col">
                          <div class="cur-tier-head-label">
                            <span class="cur-badge cur-badge--half-decent">Half Decent</span>
                          </div>
                        </th>
                        <th scope="col">
                          <div class="cur-tier-head-label">
                            <span class="cur-badge cur-badge--decent">Decent</span>
                          </div>
                        </th>
                        <th scope="col">
                          <div class="cur-tier-head-label">
                            <span class="cur-badge cur-badge--belter">Belter</span>
                          </div>
                        </th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <th scope="row">
                          <div class="cur-tier-row-head">
                            <span class="cur-tier-row-label">Threshold</span>
                            <span class="cur-tier-tip" data-tip="Play pattern to determine song ranking. Skip and Belter thresholds are in seconds.">ℹ</span>
                          </div>
                        </th>
                        <td>
                          <div class="cur-tier-cell">
                            <input type="number" name="skipThresholdSeconds" value="<%= _skipSec %>" min="15" max="45" class="cur-tier-input" />
                          </div>
                        </td>
                        <td>
                          <div class="cur-tier-static">
                            <span>&gt; 50%</span>
                          </div>
                        </td>
                        <td>
                          <div class="cur-tier-static">
                            <span>&lt; 50%</span>
                          </div>
                        </td>
                        <td>
                          <div class="cur-tier-cell">
                            <input type="number" name="completionThresholdSeconds" value="<%= _compSec %>" min="15" max="45" class="cur-tier-input" />
                          </div>
                        </td>
                      </tr>
                      <tr>
                        <th scope="row">
                          <div class="cur-tier-row-head">
                            <span class="cur-tier-row-label">Skip Weighting</span>
                            <span class="cur-tier-tip" data-tip="When a song is played, points assigned to the artist ranking score.">ℹ</span>
                          </div>
                        </th>
                        <td><div class="cur-tier-cell"><input type="number" name="skipWeight" value="<%= _skipW %>" min="-1.5" max="-0.5" step="0.25" class="cur-tier-input" /></div></td>
                        <td><div class="cur-tier-cell" style="justify-content:center"><span id="cur-hd-weight" class="cur-tier-lock" style="font-size:11px"><%= _hdW %></span></div></td>
                        <td><div class="cur-tier-cell" style="justify-content:center"><span id="cur-decent-weight" class="cur-tier-lock" style="font-size:11px"><%= _decentW %></span></div></td>
                        <td><div class="cur-tier-cell"><input type="number" name="belterWeight" value="<%= _belterW %>" min="0.5" max="1.5" step="0.25" class="cur-tier-input" /></div></td>
                      </tr>
                      <tr>
                        <th scope="row">
                          <div class="cur-tier-row-head">
                            <span class="cur-tier-row-label">Artist Ranking</span>
                            <span class="cur-tier-tip" data-tip="Artist ranking score out of 10, starting at 5. Each play adjusts the score based on the tier weighting.">ℹ</span>
                          </div>
                        </th>
                        <td><div class="cur-tier-cell"><input type="number" name="artistSkipRank" value="<%= _artistSkipRank %>" min="0" max="5" step="1" class="cur-tier-input" /></div></td>
                        <td><div class="cur-tier-static"><span>&gt; 5</span></div></td>
                        <td><div class="cur-tier-static"><span>&lt; 5</span></div></td>
                        <td><div class="cur-tier-cell"><input type="number" name="artistBelterRank" value="<%= _artistBelterRank %>" min="5" max="10" step="1" class="cur-tier-input" /></div></td>
                      </tr>
                    </tbody>
                  </table>
                </div>
                <div style="display:flex;align-items:flex-start;gap:16px;margin-top:16px">
                  <label class="field" style="flex:1;min-width:0">
                    <span>Song skip limit</span>
                    <select name="songSkipLimit" style="flex:1">
                      <option value="1"<%= _songLim == 1 ? ' selected' : '' %>>1 skip</option>
                      <option value="2"<%= _songLim == 2 ? ' selected' : '' %>>2 skips</option>
                      <option value="3"<%= _songLim == 3 ? ' selected' : '' %>>3 skips</option>
                    </select>
                    <small style="font-size:10px;color:var(--muted);text-transform:none;letter-spacing:0">Consecutive skips before auto-excluding a track.</small>
                  </label>
                  <div class="settings-smart-toggle-field" style="flex:1;min-width:0">
                    <span class="settings-smart-toggle-field-label">Artist exclusions</span>
                    <input type="hidden" name="excludeUnplayedForSkipArtists" value="" />
                    <label class="settings-smart-toggle-field-control" for="excludeUnplayedForSkipArtists">
                      <span class="settings-smart-toggle-field-title">Exclude unplayed tracks for skip-tier artists</span>
                      <span class="settings-toggle settings-toggle--smart-playlist">
                        <input id="excludeUnplayedForSkipArtists" type="checkbox" name="excludeUnplayedForSkipArtists" value="1" <%= config.smartPlaylist?.excludeUnplayedForSkipArtists ? 'checked' : '' %> />
                        <span class="settings-toggle-slider" aria-hidden="true"></span>
                      </span>
                    </label>
                    <small class="settings-smart-toggle-field-help">Also remove unplayed tracks from artists that have fallen into the skip tier.</small>
                  </div>
                  <label class="field" style="flex:1;min-width:0">
                    <span>Sync interval (minutes)</span>
                    <input type="number" name="syncIntervalMinutes" value="<%= config.smartPlaylist?.syncIntervalMinutes || 30 %>" min="5" max="1440" />
                    <small style="font-size:10px;color:var(--muted);text-transform:none;letter-spacing:0">How often Curatorr syncs the playlist to Plex.</small>
                  </label>
                </div>
              </div>
              <script>
              (function(){
                var PRESETS = {
                  cautious: {
                    desc: 'For larger libraries with a wider range of artists. Lower weighting means scores shift slowly, keeping more music in rotation for open-minded or exploratory listeners.',
                    skipThresholdSeconds: 20, completionThresholdSeconds: 20,
                    skipWeight: -0.5, belterWeight: 0.5,
                    artistSkipRank: 1, artistBelterRank: 9, songSkipLimit: 3
                  },
                  measured: {
                    desc: 'A balanced setting for a medium-sized library. Scores respond at a moderate pace — suitable for most listeners with a good mix of favourite and new artists.',
                    skipThresholdSeconds: 30, completionThresholdSeconds: 30,
                    skipWeight: -1, belterWeight: 1,
                    artistSkipRank: 2, artistBelterRank: 8, songSkipLimit: 2
                  },
                  aggressive: {
                    desc: 'For smaller, well-curated libraries where you know exactly what you like. Strong weighting means artist scores shift quickly and skips have an immediate impact.',
                    skipThresholdSeconds: 40, completionThresholdSeconds: 40,
                    skipWeight: -1.5, belterWeight: 1.5,
                    artistSkipRank: 3, artistBelterRank: 7, songSkipLimit: 1
                  }
                };
                var FIELDS = ['skipThresholdSeconds','completionThresholdSeconds','skipWeight','belterWeight','artistSkipRank','artistBelterRank'];
                var sel = document.getElementById('curPreset');
                var desc = document.getElementById('curPresetDesc');
                function updateDerived() {
                  var sw = parseFloat(document.querySelector('[name=skipWeight]').value) || -1;
                  var bw = parseFloat(document.querySelector('[name=belterWeight]').value) || 1;
                  var hd = document.getElementById('cur-hd-weight');
                  var dc = document.getElementById('cur-decent-weight');
                  if (hd) hd.textContent = +(sw / 2).toFixed(2);
                  if (dc) dc.textContent = +(bw / 2).toFixed(2);
                }
                sel.addEventListener('change', function() {
                  var p = PRESETS[this.value];
                  desc.textContent = p ? p.desc : '';
                  if (!p) return;
                  FIELDS.forEach(function(f) { var el = document.querySelector('[name='+f+']'); if (el) el.value = p[f]; });
                  // songSkipLimit is a <select>, set by value
                  var skipLimEl = document.querySelector('[name=songSkipLimit]');
                  if (skipLimEl) skipLimEl.value = p.songSkipLimit;
                  updateDerived();
                });
                FIELDS.forEach(function(f) {
                  var el = document.querySelector('[name='+f+']');
                  if (el) el.addEventListener('input', function() { sel.value = ''; desc.textContent = ''; updateDerived(); });
                });
                // Also reset preset on manual songSkipLimit change
                var skipLimEl = document.querySelector('[name=songSkipLimit]');
                if (skipLimEl) skipLimEl.addEventListener('change', function() { sel.value = ''; desc.textContent = ''; });
              })();
              </script>
              <div class="settings-card">
                <div class="settings-card-title">Playlist</div>
                <div class="settings-card-sub">Manage the Plex playlist Curatorr syncs to.</div>
                <% const _managedPlaylists = config.smartPlaylist?.managedPlaylists || []; %>
                <% const _currentPlaylistId = String(config.smartPlaylist?.playlistId || ''); %>
                <% const _currentPlaylistTitle = String(config.smartPlaylist?.playlistTitle || 'Curatorr Smart Playlist'); %>
                <div class="field field-with-action">
                  <span>Playlist name</span>
                  <div class="field-action-row">
                    <input type="text" name="playlistTitle" id="playlistTitle" value="<%= _currentPlaylistTitle %>" style="flex:1" />
                    <button type="button" class="ghost-button" id="createPlaylistBtn" style="white-space:nowrap">+ Create new</button>
                  </div>
                </div>
                <div class="field">
                  <span>Curatorr playlist</span>
                  <select id="playlistPicker" style="width:100%">
                    <option value="">— Select a playlist —</option>
                    <% _managedPlaylists.forEach(function(p) { %>
                      <option value="<%= p.ratingKey %>" <%= String(p.ratingKey) === _currentPlaylistId ? 'selected' : '' %>><%= p.title %> (ID <%= p.ratingKey %>)</option>
                    <% }); %>
                    <% if (_currentPlaylistId && !_managedPlaylists.find(function(p) { return String(p.ratingKey) === _currentPlaylistId; })) { %>
                      <option value="<%= _currentPlaylistId %>" selected><%= _currentPlaylistTitle %> (ID <%= _currentPlaylistId %>)</option>
                    <% } %>
                  </select>
                  <small id="playlistPickerHint" style="font-size:10px;color:var(--muted);text-transform:none;letter-spacing:0;margin-top:4px;display:block">
                    <% const _selPlaylist = _managedPlaylists.find(function(p) { return String(p.ratingKey) === _currentPlaylistId; }); %>
                    <% if (_selPlaylist) { %>Currently syncing to <strong><%= _selPlaylist.title %></strong> (ID <%= _currentPlaylistId %>)<% } else if (_currentPlaylistId) { %>Currently syncing to <strong><%= _currentPlaylistTitle %></strong> (ID <%= _currentPlaylistId %>)<% } else { %>No playlist selected.<% } %>
                  </small>
                  <input type="hidden" id="playlistId" name="playlistId" value="<%= _currentPlaylistId %>" />
                </div>
                <div class="plex-settings-note" style="margin-top:12px">Curatorr syncs the selected playlist automatically. Use <strong>+ Create new</strong> to create a fresh Plex playlist, or select an existing Curatorr-managed playlist from the dropdown. Changes take effect on the next sync interval.</div>
              </div>
              <button class="primary-button" type="submit">Save smart playlist settings</button>
            </form>
            <script>
            (function() {
              var picker = document.getElementById('playlistPicker');
              var hidden = document.getElementById('playlistId');
              var hint = document.getElementById('playlistPickerHint');
              var createBtn = document.getElementById('createPlaylistBtn');
              var managedIds = [<% (_managedPlaylists || []).forEach(function(p,i) { %>'<%= p.ratingKey %>'<% if (i < _managedPlaylists.length - 1) { %>,<% } %><% }); %>];

              // If current playlist isn't in managedPlaylists, resolve its real Plex name
              var legacyId = '<%= _currentPlaylistId %>';
              if (legacyId && managedIds.indexOf(legacyId) === -1) {
                fetch('/api/plex/playlists')
                  .then(function(r) { return r.json(); })
                  .then(function(data) {
                    var match = (data.playlists || []).find(function(p) { return String(p.ratingKey) === legacyId; });
                    if (!match) return;
                    // Update the fallback option with the real name
                    for (var i = 0; i < picker.options.length; i++) {
                      if (String(picker.options[i].value) === legacyId) {
                        picker.options[i].textContent = match.title + ' (ID ' + legacyId + ')';
                        hint.innerHTML = 'Currently syncing to <strong>' + match.title + '</strong> (ID ' + legacyId + ')';
                        break;
                      }
                    }
                    // Register it in managedPlaylists via create endpoint stub
                    fetch('/api/plex/managed-playlists', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
                      body: JSON.stringify({ ratingKey: legacyId, title: match.title }),
                    }).catch(function() {});
                  }).catch(function() {});
              }

              picker.addEventListener('change', function() {
                hidden.value = this.value;
                var sel = this.options[this.selectedIndex];
                hint.innerHTML = this.value ? 'Currently syncing to <strong>' + sel.textContent + '</strong> (ID ' + this.value + ')' : 'No playlist selected.';
              });
              createBtn.addEventListener('click', function() {
                var title = document.getElementById('playlistTitle').value.trim() || 'Curatorr Smart Playlist';
                createBtn.disabled = true; createBtn.textContent = 'Creating…';
                fetch('/api/plex/playlists', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
                  body: JSON.stringify({ title: title }),
                })
                  .then(function(r) { return r.json(); })
                  .then(function(data) {
                    if (data.ok && data.playlist) {
                      var opt = document.createElement('option');
                      opt.value = data.playlist.ratingKey;
                      opt.textContent = data.playlist.title;
                      opt.selected = true;
                      picker.appendChild(opt);
                      hidden.value = data.playlist.ratingKey;
                      hint.innerHTML = 'Currently syncing to <strong>' + data.playlist.title + '</strong> (ID ' + data.playlist.ratingKey + ')';
                    } else {
                      hint.textContent = 'Error: ' + (data.error || 'Could not create playlist');
                    }
                  })
                  .catch(function() { hint.textContent = 'Network error.'; })
                  .finally(function() { createBtn.disabled = false; createBtn.textContent = '+ Create new'; });
              });
            })();
            </script>
          </div>
        </div>

        <%# ── Filters ──────────────────────────────────────────────────────── %>
        <div class="settings-tab-panel" data-tab="filters">
          <div class="dash-panel">
            <form method="post" action="/settings/filters" class="settings-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div class="settings-card">
