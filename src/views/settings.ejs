            <form method="post" action="/settings/discovery" class="settings-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div class="settings-card">
                <div class="settings-card-title">Last.fm Integration</div>
                <div class="settings-card-sub">Powers the Trending Artists, Trending Tracks, and Similar Artists carousels on the Discover page. Get a free API key at <a href="https://www.last.fm/api/account/create" target="_blank" rel="noopener">last.fm/api</a>. Leave blank to hide all carousels.</div>
                <label class="field">
                  <span>API Key</span>
                  <input type="text" name="lastfmApiKey" value="<%= config.discovery?.lastfmApiKey || '' %>" placeholder="Your Last.fm API key" autocomplete="off" />
                </label>
                <label class="field">
                  <span>Region / Country</span>
                  <input type="text" name="region" value="<%= config.discovery?.region || 'united states' %>" placeholder="united states" />
                  <small class="settings-card-sub" style="margin-top:4px;display:block">Lowercase country name for regional charts (e.g. "united kingdom", "germany", "australia").</small>
