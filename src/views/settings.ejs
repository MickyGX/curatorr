                          <% if (release.isLatest) { %>
                            <span class="settings-about-pill settings-about-pill--ok">Latest</span>
                          <% } %>
                          <% if (release.isCurrent) { %>
                            <span class="settings-about-pill">Current</span>
                          <% } %>
                        </div>
                        <div class="settings-release-summary"><%= release.summary || 'Release notes are available.' %></div>
                      </div>
                      <button class="primary-button settings-release-open" type="button" data-release-index="<%= index %>">View Changelog</button>
                    </div>
                  <% }) %>
                <% } else { %>
                  <div class="settings-release-empty">No release notes were found in <code>docs/release/releases</code>.</div>
                <% } %>
              </div>
            </div>
          </div>

          <div id="settingsReleaseModalBackdrop" class="plex-modal-backdrop plex-hidden">
