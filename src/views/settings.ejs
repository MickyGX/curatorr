<%- include('partials/head', { pageTitle: title || 'Settings — Curatorr', extraCss: extraCss || ['/styles-layout.css', '/styles-settings.css'] }) %>
<body class="dash-body">
  <div class="dash-frame<%= sidebarCollapsed ? ' sidebar-collapsed' : '' %>">
    <aside class="dash-sidebar">
      <div class="dash-brand">
        <span class="dash-logo">
          <img class="nav-icon app-icon" src="/icons/curatorr-icon.svg" alt="Curatorr" onerror="this.style.display='none'" />
        </span>
        <div><div class="dash-title">Curatorr</div></div>
      </div>
      <div class="dash-nav">
        <%- include('partials/nav-categories', { navActivePage: 'settings', role: role }) %>
      </div>
      <%- include('partials/user-menu') %>
    </aside>

    <section class="dash-main">
      <div class="main-window-bar">
        <button class="sidebar-toggle main-toggle left-toggle" type="button" aria-label="Toggle sidebar">
          <img class="toggle-icon" src="/icons/sidebar-toggle.svg" alt="" />
        </button>
        <div class="main-window-title">
          <img class="main-window-icon" src="/icons/settings.svg" alt="" />
          <span class="main-window-app">Curatorr</span>
          <span class="main-window-rest">| Settings</span>
        </div>
        <div class="main-window-spacer"></div>
        <div class="main-window-status">
          <span class="status-dot"></span>
        </div>
      </div>

      <div class="dash-content">
        <% const _tab = tab || 'general'; %>
        <% const safeJson = (value) => JSON.stringify(value)
          .replace(/</g, '\\u003c')
          .replace(/\u2028/g, '\\u2028')
          .replace(/\u2029/g, '\\u2029'); %>

        <% if (success) { %>
          <div class="settings-debug" style="border-color:rgba(74,222,128,.35);background:rgba(74,222,128,.1);color:#4ade80;margin-bottom:0">Settings saved successfully.</div>
        <% } %>
        <% if (error) { %>
          <div class="settings-debug" style="margin-bottom:0"><%= error %></div>
        <% } %>

        <div class="settings-tabs" role="tablist" aria-label="Settings tabs">
          <button class="settings-tab-btn<%= _tab === 'general' ? ' is-active' : '' %>" type="button" data-tab="general">
            <img class="settings-tab-icon" src="/icons/settings.svg" alt="" />
            <span class="settings-tab-text">General</span>
          </button>
          <button class="settings-tab-btn<%= _tab === 'plex' ? ' is-active' : '' %>" type="button" data-tab="plex">
            <img class="settings-tab-icon settings-tab-icon--app" src="/icons/plex.png" alt="" />
            <span class="settings-tab-text">Plex</span>
          </button>
          <button class="settings-tab-btn<%= _tab === 'tautulli' ? ' is-active' : '' %>" type="button" data-tab="tautulli">
            <img class="settings-tab-icon settings-tab-icon--app" src="/icons/tautulli.png" alt="" />
            <span class="settings-tab-text">Tautulli</span>
          </button>
          <% if (actualRole === 'admin') { %>
            <button class="settings-tab-btn<%= _tab === 'lidarr' ? ' is-active' : '' %>" type="button" data-tab="lidarr">
              <img class="settings-tab-icon settings-tab-icon--app" src="/icons/lidarr.png" alt="" />
              <span class="settings-tab-text">Lidarr</span>
            </button>
          <% } %>
          <button class="settings-tab-btn<%= _tab === 'smart-playlist' ? ' is-active' : '' %>" type="button" data-tab="smart-playlist">
            <img class="settings-tab-icon" src="/icons/music.svg" alt="" />
            <span class="settings-tab-text">Playlists</span>
          </button>
          <button class="settings-tab-btn<%= _tab === 'discovery' ? ' is-active' : '' %>" type="button" data-tab="discovery">
            <img class="settings-tab-icon" src="/icons/search.svg" alt="" />
            <span class="settings-tab-text">Discovery</span>
          </button>

          <button class="settings-tab-btn<%= _tab === 'users' ? ' is-active' : '' %>" type="button" data-tab="users">
            <img class="settings-tab-icon" src="/icons/user-profile.svg" alt="" />
            <span class="settings-tab-text">Users</span>
          </button>
          <button class="settings-tab-btn<%= _tab === 'logs' ? ' is-active' : '' %>" type="button" data-tab="logs">
            <img class="settings-tab-icon" src="/icons/activity-queue.svg" alt="" />
            <span class="settings-tab-text">Logs</span>
          </button>
          <button class="settings-tab-btn<%= _tab === 'about' ? ' is-active' : '' %>" type="button" data-tab="about">
            <img class="settings-tab-icon" src="/icons/about.svg" alt="" />
            <span class="settings-tab-text">About</span>
          </button>
          <% if (actualRole === 'admin') { %>
            <button class="settings-tab-btn<%= _tab === 'jobs' ? ' is-active' : '' %>" type="button" data-tab="jobs">
              <img class="settings-tab-icon" src="/icons/activity-queue.svg" alt="" />
              <span class="settings-tab-text">Jobs</span>
            </button>
          <% } %>
          <button class="settings-tab-btn<%= _tab === 'appearance' ? ' is-active' : '' %>" type="button" data-tab="appearance">
            <img class="settings-tab-icon" src="/icons/sun.svg" alt="" />
            <span class="settings-tab-text">Themes</span>
          </button>
        </div>

        <%# ── General ──────────────────────────────────────────────────────── %>
        <div class="settings-tab-panel<%= _tab === 'general' ? ' is-active' : '' %>" data-tab="general">
          <div class="dash-panel">
            <form method="post" action="/settings/general" class="settings-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div class="settings-card">
                <div class="settings-card-title">Server Identity</div>
                <div class="settings-card-sub">Remote URL is used for external links and webhook callbacks. Local URL is preferred for LAN Plex SSO. Use Base URL Path when Curatorr is served behind a subpath (for example <code style="background:rgba(255,255,255,.08);padding:2px 6px;border-radius:5px;font-size:11px">/curatorr</code>).</div>
                <label class="field">
                  <span>Server name</span>
                  <input type="text" name="serverName" value="<%= config.general?.serverName || 'Curatorr' %>" placeholder="Curatorr" />
                </label>
                <label class="field">
                  <span>Remote URL</span>
                  <input type="text" name="remoteUrl" value="<%= config.general?.remoteUrl || '' %>" placeholder="https://curatorr.example.com" />
                </label>
                <label class="field">
                  <span>Local URL</span>
                  <input type="text" name="localUrl" value="<%= config.general?.localUrl || '' %>" placeholder="http://192.168.0.x:7676" />
                </label>
                <label class="field">
                  <span>Base URL Path</span>
                  <input type="text" name="basePath" value="<%= config.general?.basePath || '' %>" placeholder="/curatorr" />
                </label>
                <label class="settings-toggle" style="margin-top:4px">
                  <input type="checkbox" name="restrictGuests" value="1" <%= config.general?.restrictGuests ? 'checked' : '' %> />
                  <span class="settings-toggle-slider" aria-hidden="true"></span>
                  <span class="settings-toggle-text">Restrict guest users</span>
                </label>
              </div>
              <button class="primary-button" type="submit">Save general settings</button>
            </form>
          </div>
        </div>

        <%# ── Plex ─────────────────────────────────────────────────────────── %>
        <div class="settings-tab-panel<%= _tab === 'plex' ? ' is-active' : '' %>" data-tab="plex">
          <div class="dash-panel">
            <form method="post" action="/settings/plex" class="settings-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div class="settings-card">
                <div class="settings-card-title">App URLs</div>
                <div class="settings-card-sub">Local URL is used inside your network. Remote URL is used for external access. Local URL is preferred when set.</div>
                <label class="field">
                  <span>Local URL</span>
                  <input type="text" name="plexLocalUrl" value="<%= config.plex?.localUrl || config.plex?.url || '' %>" placeholder="http://192.168.1.x:32400" />
                </label>
                <label class="field">
                  <span>Remote URL</span>
                  <input type="text" name="plexRemoteUrl" value="<%= config.plex?.remoteUrl || '' %>" placeholder="https://plex.example.com" />
                </label>
              </div>
              <div class="settings-card plex-settings-card">
                <div class="settings-card-title">Plex Access</div>
                <div class="settings-card-sub">Uses the Local URL first, then the Remote URL.</div>
                <div class="plex-settings-fields">
                  <label class="field field-with-action">
                    <span>Plex Token</span>
                    <div class="field-action-row">
                      <input id="plex-token-input" type="password" name="plexToken" value="" placeholder="<%= config.plex?.tokenSet ? '(saved — leave blank to keep)' : 'Enter Plex token' %>" data-plex-field="token" />
                      <button class="icon-button" type="button" aria-label="Show Plex token" data-visibility-toggle="plex-token-input" data-visibility-state="hidden">
                        <img src="/icons/view-off.svg" alt="" />
                      </button>
                    </div>
                  </label>
                  <label class="field field-with-action">
                    <span>Machine ID</span>
                    <div class="field-action-row">
                      <input id="plex-machine-input" type="password" name="machineId" value="<%= config.plex?.machineId || '' %>" placeholder="Plex server machine identifier" data-plex-field="machine" />
                      <button class="icon-button" type="button" aria-label="Show machine ID" data-visibility-toggle="plex-machine-input" data-visibility-state="hidden">
                        <img src="/icons/view-off.svg" alt="" />
                      </button>
                    </div>
                  </label>
                  <label class="field">
                    <span>Plex Admin User</span>
                    <input type="text" name="plexAdminUser" value="<%= config.plex?.adminUser || '' %>" placeholder="admin@plex.tv" />
                  </label>
                  <div class="plex-settings-actions" style="display:flex;gap:8px;margin-top:4px">
                    <button class="ghost-button" type="button" data-plex-action="token">Get Plex Token</button>
                    <button class="ghost-button" type="button" data-plex-action="machine">Get Plex Machine</button>
                  </div>
                </div>
                <div class="plex-settings-note">Tip: Local URL is preferred when set.</div>
              </div>
              <% if (config.plex?.availableLibraries?.length) { %>
              <div class="settings-card">
                <div class="settings-card-title">Music Libraries</div>
                <div class="settings-card-sub">Select which Plex music libraries Curatorr should monitor.</div>
                <div class="settings-checklist" style="display:flex;flex-direction:column;gap:8px">
                  <% config.plex.availableLibraries.forEach(function(lib) { %>
                    <label class="settings-toggle">
                      <input type="checkbox" name="libraries" value="<%= lib.key %>" <%= (config.plex?.libraries || []).includes(lib.key) ? 'checked' : '' %> />
                      <span class="settings-toggle-slider" aria-hidden="true"></span>
                      <span class="settings-toggle-text"><%= lib.title %></span>
                    </label>
                  <% }) %>
                </div>
              </div>
              <% } %>
              <button class="primary-button" type="submit">Save Plex settings</button>
            </form>
          </div>
        </div>

        <%# ── Tautulli ─────────────────────────────────────────────────────── %>
        <div class="settings-tab-panel<%= _tab === 'tautulli' ? ' is-active' : '' %>" data-tab="tautulli">
          <div class="dash-panel">
            <form method="post" action="/settings/tautulli" class="settings-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div class="settings-card">
                <div class="settings-card-title">App URLs</div>
                <div class="settings-card-sub">Local URL is used inside your network. Remote URL is used for external access. Local URL is preferred when set.</div>
                <label class="field">
                  <span>Local URL</span>
                  <input type="text" name="tautulliLocalUrl" value="<%= config.tautulli?.localUrl || config.tautulli?.url || '' %>" placeholder="http://192.168.1.x:8181" />
                </label>
                <label class="field">
                  <span>Remote URL</span>
                  <input type="text" name="tautulliRemoteUrl" value="<%= config.tautulli?.remoteUrl || '' %>" placeholder="https://tautulli.example.com" />
                </label>
              </div>
              <div class="settings-card plex-settings-card">
                <div class="settings-card-title">Tautulli Access</div>
                <div class="settings-card-sub">
                  In Tautulli: Settings → Notification Agents → Webhook<br />
                  URL: <code style="background:rgba(255,255,255,.08);padding:2px 6px;border-radius:5px;font-size:11px"><%= (config.general?.remoteUrl || config.general?.localUrl || 'http://curatorr:7676').replace(/\/$/, '') %>/webhook/tautulli</code><br />
                  Method: POST · Triggers: Playback Start, Stop, Pause, Resume, Watched
                </div>
                <div class="plex-settings-fields">
                  <label class="field field-with-action">
                    <span>API key</span>
                    <div class="field-action-row">
                      <input id="tautulli-apikey-input" type="password" name="apiKey" value="<%= config.tautulli?.apiKey || '' %>" placeholder="Tautulli API key" />
                      <button class="icon-button" type="button" aria-label="Show API key" data-visibility-toggle="tautulli-apikey-input" data-visibility-state="hidden">
                        <img src="/icons/view-off.svg" alt="" />
                      </button>
                    </div>
                  </label>
                </div>
              </div>
              <button class="primary-button" type="submit">Save Tautulli settings</button>
            </form>
          </div>
        </div>

        <%# ── Lidarr ───────────────────────────────────────────────────────── %>
        <% if (actualRole === 'admin') { %>
          <div class="settings-tab-panel<%= _tab === 'lidarr' ? ' is-active' : '' %>" data-tab="lidarr">
            <div class="dash-panel">
              <form method="post" action="/settings/lidarr" class="settings-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <div class="settings-card">
                  <div class="settings-card-title">App URLs</div>
                  <div class="settings-card-sub">Local URL is used inside your network. Remote URL is used for external access. Local URL is preferred when set.</div>
                  <label class="field">
                    <span>Local URL</span>
                    <input type="text" name="lidarrLocalUrl" value="<%= config.lidarr?.localUrl || config.lidarr?.url || '' %>" placeholder="http://192.168.1.x:8686" />
                  </label>
                  <label class="field">
                    <span>Remote URL</span>
                    <input type="text" name="lidarrRemoteUrl" value="<%= config.lidarr?.remoteUrl || '' %>" placeholder="https://lidarr.example.com" />
                  </label>
                </div>
                <div class="settings-card plex-settings-card">
                  <div class="settings-card-title">Lidarr Access</div>
                  <div class="settings-card-sub">Connect to Lidarr for music library management. Find the API key in Lidarr → Settings → General.</div>
                  <div class="plex-settings-fields">
                    <label class="field field-with-action">
                      <span>API key</span>
                      <div class="field-action-row">
                        <input id="lidarr-apikey-input" type="password" name="apiKey" value="<%= config.lidarr?.apiKey || '' %>" placeholder="Lidarr API key" />
                        <button class="icon-button" type="button" aria-label="Show API key" data-visibility-toggle="lidarr-apikey-input" data-visibility-state="hidden">
                          <img src="/icons/view-off.svg" alt="" />
                        </button>
                      </div>
                    </label>
                  </div>
                </div>
                <div class="settings-card">
                  <div class="settings-card-title">Automation</div>
                  <div class="settings-card-sub">Only admins can change these settings. Access is role-based: admins and co-admins always qualify, and power users can use it when automation is enabled.</div>
                  <label class="settings-toggle" style="margin-top:4px">
                    <input type="checkbox" name="automationEnabled" value="1" <%= lidarrAutomation?.automationEnabled ? 'checked' : '' %> />
                    <span class="settings-toggle-slider" aria-hidden="true"></span>
                    <span class="settings-toggle-text">Enable Lidarr automation</span>
                  </label>
                  <label class="field">
                    <span>Automation scope</span>
                    <select name="automationScope">
                      <option value="off" <%= (lidarrAutomation?.automationScope || 'off') === 'off' ? 'selected' : '' %>>Off</option>
                      <option value="global" <%= lidarrAutomation?.automationScope === 'global' ? 'selected' : '' %>>Role based</option>
                    </select>
                  </label>
                  <label class="settings-toggle" style="margin-top:4px">
                    <input type="checkbox" name="autoTriggerManualSearch" value="1" <%= lidarrAutomation?.autoTriggerManualSearch ? 'checked' : '' %> />
                    <span class="settings-toggle-slider" aria-hidden="true"></span>
                    <span class="settings-toggle-text">Auto trigger manual search after starter album is added</span>
                  </label>
                  <div class="settings-card-sub" style="margin-top:2px">When enabled, Curatorr will immediately queue a Lidarr <code style="background:rgba(255,255,255,.08);padding:2px 6px;border-radius:5px;font-size:11px">AlbumSearch</code> for the starter album after it is monitored.</div>
                  <label class="settings-toggle" style="margin-top:12px">
                    <input type="checkbox" name="autoAddArtists" value="1" <%= lidarrAutomation?.autoAddArtists ? 'checked' : '' %> />
                    <span class="settings-toggle-slider" aria-hidden="true"></span>
                    <span class="settings-toggle-text">Automatically add top suggested artists to Lidarr</span>
                  </label>
                  <div class="settings-card-sub" style="margin-top:2px">When enabled, Curatorr will automatically queue the highest-scoring artist suggestion for each eligible user during the Lidarr review job (runs every 30 minutes). Artists must score 7.0 or above to qualify. Weekly role quotas still apply — if quota is full the artist moves into the queue for later.</div>
                  <div class="settings-grid settings-grid--2" style="margin-top:12px">
                    <label class="field">
                      <span>Fallback search attempts</span>
                      <input type="number" min="1" max="10" name="manualSearchFallbackAttempts" value="<%= lidarrAutomation?.manualSearchFallbackAttempts ?? 2 %>" />
                    </label>
                    <label class="field">
                      <span>Fallback delay (hours)</span>
                      <input type="number" min="1" max="168" name="manualSearchFallbackHours" value="<%= lidarrAutomation?.manualSearchFallbackHours ?? 24 %>" />
                    </label>
                    <label class="field">
                      <span>Minimum peers for fallback grab</span>
                      <input type="number" min="0" max="999" name="minimumReleasePeers" value="<%= lidarrAutomation?.minimumReleasePeers ?? 2 %>" />
                    </label>
                    <label class="settings-toggle field" style="align-self:end;margin:0">
                      <input type="checkbox" name="preferApprovedReleases" value="1" <%= lidarrAutomation?.preferApprovedReleases !== false ? 'checked' : '' %> />
                      <span class="settings-toggle-slider" aria-hidden="true"></span>
                      <span class="settings-toggle-text">Prefer approved releases in fallback grab</span>
                    </label>
                  </div>
                  <div class="settings-card-sub" style="margin-top:2px">If Lidarr search finishes without files, Curatorr can re-monitor, retry search, and eventually choose the best release by peers and score for download.</div>
                  <div class="settings-card-sub" style="margin-top:10px">Weekly content quotas by role.</div>
                  <div class="settings-grid settings-grid--2">
                    <label class="field">
                      <span>Admin artists per week</span>
                      <input type="text" value="Unlimited" disabled />
                    </label>
                    <label class="field">
                      <span>Admin albums per week</span>
                      <input type="text" value="Unlimited" disabled />
                    </label>
                    <label class="field">
                      <span>Co-admin artists per week</span>
                      <input type="number" min="-1" max="999" name="coAdminWeeklyArtists" value="<%= lidarrAutomation?.roleQuotas?.['co-admin']?.weeklyArtists ?? 3 %>" />
                    </label>
                    <label class="field">
                      <span>Co-admin albums per week</span>
                      <input type="number" min="-1" max="999" name="coAdminWeeklyAlbums" value="<%= lidarrAutomation?.roleQuotas?.['co-admin']?.weeklyAlbums ?? 6 %>" />
                    </label>
                    <label class="field">
                      <span>Power user artists per week</span>
                      <input type="number" min="-1" max="999" name="powerUserWeeklyArtists" value="<%= lidarrAutomation?.roleQuotas?.['power-user']?.weeklyArtists ?? 1 %>" />
                    </label>
                    <label class="field">
                      <span>Power user albums per week</span>
                      <input type="number" min="-1" max="999" name="powerUserWeeklyAlbums" value="<%= lidarrAutomation?.roleQuotas?.['power-user']?.weeklyAlbums ?? 2 %>" />
                    </label>
                    <label class="field">
                      <span>User artists per week</span>
                      <input type="number" min="-1" max="999" name="userWeeklyArtists" value="<%= lidarrAutomation?.roleQuotas?.user?.weeklyArtists ?? 0 %>" />
                    </label>
                    <label class="field">
                      <span>User albums per week</span>
                      <input type="number" min="-1" max="999" name="userWeeklyAlbums" value="<%= lidarrAutomation?.roleQuotas?.user?.weeklyAlbums ?? 0 %>" />
                    </label>
                  </div>
                  <small style="font-size:10px;color:var(--muted);text-transform:none;letter-spacing:0">Use <code style="background:rgba(255,255,255,.08);padding:2px 6px;border-radius:5px;font-size:11px">-1</code> for unlimited quotas.</small>
                </div>
                <button class="primary-button" type="submit">Save Lidarr settings</button>
              </form>
            </div>
          </div>
        <% } %>

        <%# ── Smart Playlist ───────────────────────────────────────────────── %>
        <div class="settings-tab-panel<%= _tab === 'smart-playlist' ? ' is-active' : '' %>" data-tab="smart-playlist">
          <div class="dash-panel">
            <form method="post" action="/settings/smart-playlist" class="settings-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div class="settings-card">
                <div class="settings-card-title">Curatorr Rules</div>
                <div class="settings-card-sub">Control how your listening habits affect your smart playlists.</div>
                <%
                  const _skipSec    = config.smartPlaylist?.skipThresholdSeconds      || 30;
                  const _compSec    = config.smartPlaylist?.completionThresholdSeconds || 30;
                  const _songLim    = config.smartPlaylist?.songSkipLimit              || 2;
                  const _skipW   = config.smartPlaylist?.skipWeight   ?? -1;
                  const _belterW = config.smartPlaylist?.belterWeight ?? 1;
                  // Half Decent and Decent are always derived — not user-settable
                  const _hdW     = +(_skipW / 2).toFixed(2);
                  const _decentW = +(_belterW / 2).toFixed(2);
                  const _artistSkipRank = config.smartPlaylist?.artistSkipRank ?? 2;
                  const _artistBelterRank = config.smartPlaylist?.artistBelterRank ?? 8;
                %>
                <div class="settings-smart-preset">
                  <label class="field">
                    <span>Default preset for new users</span>
                    <select name="defaultPreset" id="defaultPresetSelect" onchange="applyPresetDefaults(this.value)">
                      <% const _defaultPreset = config.smartPlaylist?.defaultPreset || 'measured'; %>
                      <option value="cautious" <%= _defaultPreset === 'cautious' ? 'selected' : '' %>>Cautious — larger playlist, wide range of artists</option>
                      <option value="measured" <%= _defaultPreset === 'measured' ? 'selected' : '' %>>Measured — medium playlist, good mix of artists</option>
                      <option value="aggressive" <%= _defaultPreset === 'aggressive' ? 'selected' : '' %>>Aggressive — smaller playlist, I know what I like</option>
                    </select>
                  </label>
                  <small class="settings-smart-helper">Applied to new users during setup. Existing users keep their chosen preset. Changing this updates the fields below.</small>
                </div>
                <div class="cur-tier-table-wrap">
                  <table class="cur-tier-table">
                    <colgroup>
                      <col class="cur-tier-col cur-tier-col--label" />
                      <col class="cur-tier-col" />
                      <col class="cur-tier-col" />
                      <col class="cur-tier-col" />
                      <col class="cur-tier-col" />
                    </colgroup>
                    <thead>
                      <tr>
                        <th scope="col">
                          <div class="cur-tier-head-label">
                            <span class="cur-badge cur-badge--curatorr">Curatorr</span>
                          </div>
                        </th>
                        <th scope="col">
                          <div class="cur-tier-head-label">
                            <span class="cur-badge cur-badge--skip">Skip</span>
                          </div>
                        </th>
                        <th scope="col">
                          <div class="cur-tier-head-label">
                            <span class="cur-badge cur-badge--half-decent">Half Decent</span>
                          </div>
                        </th>
                        <th scope="col">
                          <div class="cur-tier-head-label">
                            <span class="cur-badge cur-badge--decent">Decent</span>
                          </div>
                        </th>
                        <th scope="col">
                          <div class="cur-tier-head-label">
                            <span class="cur-badge cur-badge--belter">Belter</span>
                          </div>
                        </th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <th scope="row">
                          <div class="cur-tier-row-head">
                            <span class="cur-tier-row-label">Threshold</span>
                            <span class="cur-tier-tip" data-tip="Play pattern to determine song ranking. Skip and Belter thresholds are in seconds.">ℹ</span>
                          </div>
                        </th>
                        <td>
                          <div class="cur-tier-cell">
                            <input type="number" name="skipThresholdSeconds" value="<%= _skipSec %>" min="15" max="45" class="cur-tier-input" />
                          </div>
                        </td>
                        <td>
                          <div class="cur-tier-static">
                            <span>&gt; 50%</span>
                          </div>
                        </td>
                        <td>
                          <div class="cur-tier-static">
                            <span>&lt; 50%</span>
                          </div>
                        </td>
                        <td>
                          <div class="cur-tier-cell">
                            <input type="number" name="completionThresholdSeconds" value="<%= _compSec %>" min="15" max="45" class="cur-tier-input" />
                          </div>
                        </td>
                      </tr>
                      <tr>
                        <th scope="row">
                          <div class="cur-tier-row-head">
                            <span class="cur-tier-row-label">Skip Weighting</span>
                            <span class="cur-tier-tip" data-tip="When a song is played, points assigned to the artist ranking score.">ℹ</span>
                          </div>
                        </th>
                        <td><div class="cur-tier-cell"><input type="number" name="skipWeight" value="<%= _skipW %>" min="-1.5" max="-0.5" step="0.25" class="cur-tier-input" /></div></td>
                        <td><div class="cur-tier-cell cur-tier-cell--static"><span id="cur-hd-weight" class="cur-tier-lock settings-smart-tier-lock"><%= _hdW %></span></div></td>
                        <td><div class="cur-tier-cell cur-tier-cell--static"><span id="cur-decent-weight" class="cur-tier-lock settings-smart-tier-lock"><%= _decentW %></span></div></td>
                        <td><div class="cur-tier-cell"><input type="number" name="belterWeight" value="<%= _belterW %>" min="0.5" max="1.5" step="0.25" class="cur-tier-input" /></div></td>
                      </tr>
                      <tr>
                        <th scope="row">
                          <div class="cur-tier-row-head">
                            <span class="cur-tier-row-label">Artist Ranking</span>
                            <span class="cur-tier-tip" data-tip="Artist ranking score out of 10, starting at 5. Each play adjusts the score based on the tier weighting.">ℹ</span>
                          </div>
                        </th>
                        <td><div class="cur-tier-cell"><input type="number" name="artistSkipRank" value="<%= _artistSkipRank %>" min="0" max="5" step="1" class="cur-tier-input" /></div></td>
                        <td><div class="cur-tier-static"><span>&gt; 5</span></div></td>
                        <td><div class="cur-tier-static"><span>&lt; 5</span></div></td>
                        <td><div class="cur-tier-cell"><input type="number" name="artistBelterRank" value="<%= _artistBelterRank %>" min="5" max="10" step="1" class="cur-tier-input" /></div></td>
                      </tr>
                    </tbody>
                  </table>
                </div>
                <div class="settings-smart-grid">
                  <label class="field settings-smart-field">
                    <span>Song skip limit</span>
                    <select name="songSkipLimit">
                      <option value="1"<%= _songLim == 1 ? ' selected' : '' %>>1 skip</option>
                      <option value="2"<%= _songLim == 2 ? ' selected' : '' %>>2 skips</option>
                      <option value="3"<%= _songLim == 3 ? ' selected' : '' %>>3 skips</option>
                    </select>
                    <small class="settings-smart-helper">Consecutive skips before auto-excluding a track.</small>
                  </label>

                </div>
              </div>
              <script>
              var SMART_PRESET_VALUES = {
                cautious:   { skipThresholdSeconds: 20, completionThresholdSeconds: 20, skipWeight: -0.5, belterWeight: 0.5,  artistSkipRank: 1, artistBelterRank: 9, songSkipLimit: 3 },
                measured:   { skipThresholdSeconds: 30, completionThresholdSeconds: 30, skipWeight: -1,   belterWeight: 1,    artistSkipRank: 2, artistBelterRank: 8, songSkipLimit: 2 },
                aggressive: { skipThresholdSeconds: 40, completionThresholdSeconds: 40, skipWeight: -1.5, belterWeight: 1.5,  artistSkipRank: 3, artistBelterRank: 7, songSkipLimit: 1 },
              };

              function applyPresetDefaults(preset) {
                var p = SMART_PRESET_VALUES[preset];
                if (!p) return;
                var fields = ['skipThresholdSeconds','completionThresholdSeconds','skipWeight','belterWeight','artistSkipRank','artistBelterRank'];
                fields.forEach(function(f) {
                  var el = document.querySelector('[name=' + f + ']');
                  if (el) { el.value = p[f]; el.dispatchEvent(new Event('input')); }
                });
                // Also update songSkipLimit select
                var sl = document.querySelector('[name=songSkipLimit]');
                if (sl) sl.value = String(p.songSkipLimit);
              }

              (function(){
                function updateDerived() {
                  var sw = parseFloat(document.querySelector('[name=skipWeight]').value) || -1;
                  var bw = parseFloat(document.querySelector('[name=belterWeight]').value) || 1;
                  var hd = document.getElementById('cur-hd-weight');
                  var dc = document.getElementById('cur-decent-weight');
                  if (hd) hd.textContent = +(sw / 2).toFixed(2);
                  if (dc) dc.textContent = +(bw / 2).toFixed(2);
                }
                ['skipWeight','belterWeight'].forEach(function(f) {
                  var el = document.querySelector('[name='+f+']');
                  if (el) el.addEventListener('input', updateDerived);
                });
              })();
              </script>
              <button class="primary-button" type="submit">Save Curatorr rules</button>
            </form>

            <%# ── Crescive / Curative playlist settings ──────────────────── %>
            <% if (actualRole === 'admin') { %>
            <form method="post" action="/settings/smart-playlist-types" class="settings-form settings-playlist-types-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <%
                const _cr = config.smartPlaylist?.crescive || {};
                const _cu = config.smartPlaylist?.curative || {};
                const _ar = config.smartPlaylist?.additionRules || {};
                const _sr = config.smartPlaylist?.subtractionRules?.skip || [];
                function _pct(val, def) { return Math.round(((val ?? def) * 100)); }
              %>

              <%# Crescive %>
              <div class="settings-card settings-playlist-types-card">
                <div class="settings-card-title">Crescive Playlist — Starting Position</div>
                <div class="settings-card-sub">Starts refined and grows over time. Percentages control how much of each artist tier is included on first build.</div>
                <div class="settings-type-grid">
                  <label class="field"><span>Fav artist tracks</span><div class="settings-pct-row"><input type="number" name="cr_favArtistTrackPct" value="<%= _pct(_cr.favouriteArtistTrackPct, 0.80) %>" min="1" max="100" /><span class="settings-pct-sym">%</span></div></label>
                  <label class="field"><span>Fav genre artists</span><div class="settings-pct-row"><input type="number" name="cr_favGenreArtistPct" value="<%= _pct(_cr.favouriteGenreArtistPct, 0.80) %>" min="1" max="100" /><span class="settings-pct-sym">%</span></div></label>
                  <label class="field"><span>Fav genre tracks</span><div class="settings-pct-row"><input type="number" name="cr_favGenreTrackPct" value="<%= _pct(_cr.favouriteGenreTrackPct, 0.20) %>" min="1" max="100" /><span class="settings-pct-sym">%</span></div></label>
                  <label class="field"><span>Other artists</span><div class="settings-pct-row"><input type="number" name="cr_otherArtistPct" value="<%= _pct(_cr.otherGenreArtistPct, 0.20) %>" min="0" max="100" /><span class="settings-pct-sym">%</span></div></label>
                  <label class="field"><span>Other tracks</span><div class="settings-pct-row"><input type="number" name="cr_otherTrackPct" value="<%= _pct(_cr.otherGenreTrackPct, 0.20) %>" min="1" max="100" /><span class="settings-pct-sym">%</span></div></label>
                </div>
              </div>

              <%# Curative %>
              <div class="settings-card">
                <div class="settings-card-title">Curative Playlist — Starting Position</div>
                <div class="settings-card-sub">Starts large and is pruned over time. Replaces your existing Curatorr playlist.</div>
                <div class="settings-type-grid">
                  <label class="field"><span>Fav artist tracks</span><div class="settings-pct-row"><input type="number" name="cu_favArtistTrackPct" value="<%= _pct(_cu.favouriteArtistTrackPct, 1.00) %>" min="1" max="100" /><span class="settings-pct-sym">%</span></div></label>
                  <label class="field"><span>Fav genre artists</span><div class="settings-pct-row"><input type="number" name="cu_favGenreArtistPct" value="<%= _pct(_cu.favouriteGenreArtistPct, 1.00) %>" min="1" max="100" /><span class="settings-pct-sym">%</span></div></label>
                  <label class="field"><span>Fav genre tracks</span><div class="settings-pct-row"><input type="number" name="cu_favGenreTrackPct" value="<%= _pct(_cu.favouriteGenreTrackPct, 0.80) %>" min="1" max="100" /><span class="settings-pct-sym">%</span></div></label>
                  <label class="field"><span>Other artists</span><div class="settings-pct-row"><input type="number" name="cu_otherArtistPct" value="<%= _pct(_cu.otherGenreArtistPct, 0.50) %>" min="0" max="100" /><span class="settings-pct-sym">%</span></div></label>
                  <label class="field"><span>Other tracks</span><div class="settings-pct-row"><input type="number" name="cu_otherTrackPct" value="<%= _pct(_cu.otherGenreTrackPct, 0.50) %>" min="1" max="100" /><span class="settings-pct-sym">%</span></div></label>
                </div>
              </div>

              <%# Addition rules %>
              <div class="settings-card">
                <div class="settings-card-title">Addition Rules</div>
                <div class="settings-card-sub">When an artist's tier threshold is reached, the next highest-rated unplayed tracks are added to both playlists.</div>
                <table class="cur-tier-table" style="width:100%">
                  <thead><tr><th>Artist tier</th><th>% of their tracks played</th><th>Tracks to add</th></tr></thead>
                  <tbody>
                    <% [['belter','Belter',0.50,15],['decent','Decent',0.80,10],['halfDecent','Half Decent',1.00,5]].forEach(function(row) { %>
                    <% const _arRow = _ar[row[0]] || {}; %>
                    <tr>
                      <td><span class="cur-badge cur-badge--<%= row[0] === 'halfDecent' ? 'half-decent' : row[0] %>"><%= row[1] %></span></td>
                      <td><div class="settings-pct-row"><input type="number" name="ar_<%= row[0] %>_pct" value="<%= Math.round((_arRow.playedPct ?? row[2]) * 100) %>" min="1" max="100" style="width:70px" /><span class="settings-pct-sym">%</span></div></td>
                      <td><input type="number" name="ar_<%= row[0] %>_count" value="<%= _arRow.addCount ?? row[3] %>" min="1" max="50" style="width:70px" /></td>
                    </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>

              <%# Subtraction rules %>
              <div class="settings-card">
                <div class="settings-card-title">Subtraction Rules</div>
                <div class="settings-card-sub">When an artist's tracks are predominantly skipped, the lowest-rated unplayed or previously skipped tracks are removed from both playlists.</div>
                <table class="cur-tier-table" style="width:100%">
                  <thead><tr><th>% of their tracks exposed</th><th>Tracks to remove</th></tr></thead>
                  <tbody>
                    <% [[0.20,15],[0.50,10],[0.80,5]].forEach(function(def, i) { %>
                    <% const _srRow = _sr[i] || {}; %>
                    <tr>
                      <td><div class="settings-pct-row"><input type="number" name="sr_skip_<%= i %>_pct" value="<%= Math.round((_srRow.playedPct ?? def[0]) * 100) %>" min="1" max="100" style="width:70px" /><span class="settings-pct-sym">%</span></div></td>
                      <td><input type="number" name="sr_skip_<%= i %>_count" value="<%= _srRow.removeCount ?? def[1] %>" min="1" max="50" style="width:70px" /></td>
                    </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>

              <button class="primary-button" type="submit">Save playlist type settings</button>
            </form>

            <%# ── Global Playlists ────────────────────────────────────────── %>
            <%# Builder card %>
            <div class="settings-card gp-builder-card">
              <div class="settings-card-title">Create Global Playlist</div>
              <div class="settings-card-sub">Filters are applied per user using their play/skip history. Preview shows live counts before saving.</div>

              <div class="field">
                <span>Playlist name</span>
                <input type="text" id="gp-name" placeholder="e.g. Belting Belters" style="width:100%" />
              </div>

              <div class="gp-builder-grid">
                <div class="gp-filter-section">
                  <div class="gp-filter-label">Artist tier</div>
                  <div class="gp-filter-chips">
                    <% [['belter','Belter','belter'],['decent','Decent','decent'],['halfDecent','Half-Decent','half-decent'],['skip','Skip','skip'],['unranked','Unranked','muted']].forEach(function(t) { %>
                    <label class="gp-chip-label">
                      <input type="checkbox" class="gp-artist-tier" value="<%= t[0] %>" />
                      <span class="cur-badge cur-badge--<%= t[2] %>"><%= t[1] %></span>
                    </label>
                    <% }); %>
                    <label class="gp-chip-label gp-chip-all">
                      <input type="checkbox" class="gp-artist-tier-all" checked />
                      <span class="cur-badge">All</span>
                    </label>
                  </div>
                </div>

                <div class="gp-filter-section">
                  <div class="gp-filter-label">Track tier</div>
                  <div class="gp-filter-chips">
                    <% [['belter','Belter','belter'],['decent','Decent','decent'],['halfDecent','Half-Decent','half-decent'],['skip','Skip','skip'],['unplayed','Unplayed','muted']].forEach(function(t) { %>
                    <label class="gp-chip-label">
                      <input type="checkbox" class="gp-track-tier" value="<%= t[0] %>" />
                      <span class="cur-badge cur-badge--<%= t[2] %>"><%= t[1] %></span>
                    </label>
                    <% }); %>
                    <label class="gp-chip-label gp-chip-all">
                      <input type="checkbox" class="gp-track-tier-all" checked />
                      <span class="cur-badge">All</span>
                    </label>
                  </div>
                </div>

                <div class="gp-filter-section gp-filter-section--inline">
                  <label class="field" style="flex:1">
                    <span>Top N per artist</span>
                    <input type="number" id="gp-top-n" min="1" max="999" placeholder="All tracks" />
                  </label>
                  <label class="field" style="flex:1">
                    <span>Max total tracks</span>
                    <input type="number" id="gp-max-tracks" min="1" placeholder="No limit" />
                  </label>
                  <label class="field" style="flex:1">
                    <span>Sort tracks by</span>
                    <select id="gp-sort-by">
                      <option value="ratingCount">Global rating count</option>
                      <option value="tierWeight">Tier weight</option>
                      <option value="playCount">Play count</option>
                    </select>
                  </label>
                </div>
              </div>

              <%# Preview %>
              <div class="gp-preview-bar">
                <div class="gp-preview-left">
                  <span class="gp-preview-label">Preview for</span>
                  <select id="gp-preview-user" class="settings-select gp-preview-select">
                    <option value="">— All users (avg) —</option>
                    <% (allUserIds || []).forEach(function(uid) { %>
                    <option value="<%= uid %>"><%= uid %></option>
                    <% }); %>
                  </select>
                </div>
                <div class="gp-preview-counts" id="gp-preview-counts">
                  <span class="gp-preview-stat"><span class="gp-preview-num" id="gp-prev-artists">—</span> <span class="gp-preview-unit">artists</span></span>
                  <span class="gp-preview-sep">·</span>
                  <span class="gp-preview-stat"><span class="gp-preview-num" id="gp-prev-tracks">—</span> <span class="gp-preview-unit">tracks</span></span>
                  <span class="gp-preview-avg" id="gp-prev-avg-wrap" style="display:none">
                    <span class="gp-preview-sep">·</span> avg across all users: <strong id="gp-prev-avg"></strong>
                  </span>
                </div>
              </div>

              <div class="gp-builder-actions">
                <button class="primary-button" id="gp-create-btn" type="button">Create Playlist</button>
                <span class="gp-create-msg" id="gp-create-msg"></span>
              </div>
            </div>

            <%# Existing global playlists %>
            <div id="gp-list">
              <% (globalPlaylists || []).forEach(function(gp) { %>
              <div class="settings-card gp-card" data-gp-id="<%= gp.id %>">
                <div class="gp-card-header">
                  <span class="settings-card-title gp-card-name"><%= gp.name %></span>
                  <div class="gp-card-actions">
                    <label class="gp-toggle-wrap" title="<%= gp.enabled ? 'Enabled' : 'Disabled' %>">
                      <input type="checkbox" class="gp-toggle" data-gp-id="<%= gp.id %>" <%= gp.enabled ? 'checked' : '' %> />
                      <span class="gp-toggle-label"><%= gp.enabled ? 'Enabled' : 'Disabled' %></span>
                    </label>
                    <button class="btn btn-sm btn-ghost-danger gp-delete-btn" data-gp-id="<%= gp.id %>">Delete</button>
                  </div>
                </div>
                <div class="gp-card-rules">
                  <% const _at = (gp.rules?.artistTiers || []); const _tt = (gp.rules?.trackTiers || []); %>
                  <span class="gp-rule-chip">Artists: <%= _at.length ? _at.join(', ') : 'all' %></span>
                  <span class="gp-rule-chip">Tracks: <%= _tt.length ? _tt.join(', ') : 'all' %></span>
                  <% if (gp.rules?.topNPerArtist) { %><span class="gp-rule-chip">Top <%= gp.rules.topNPerArtist %>/artist</span><% } %>
                  <% if (gp.rules?.maxTracks) { %><span class="gp-rule-chip">Max <%= gp.rules.maxTracks %> tracks</span><% } %>
                </div>
              </div>
              <% }); %>
              <% if (!(globalPlaylists || []).length) { %>
              <div class="cur-empty" id="gp-empty">No global playlists yet. Create one below.</div>
              <% } %>
            </div>

            <script>
            (function() {
              var _csrf = '<%= csrfToken %>';
              var previewTimer = null;

              function getBuilderRules() {
                var artistTiers = [];
                if (!document.querySelector('.gp-artist-tier-all').checked) {
                  document.querySelectorAll('.gp-artist-tier:checked').forEach(function(c) { artistTiers.push(c.value); });
                }
                var trackTiers = [];
                if (!document.querySelector('.gp-track-tier-all').checked) {
                  document.querySelectorAll('.gp-track-tier:checked').forEach(function(c) { trackTiers.push(c.value); });
                }
                return {
                  artistTiers: artistTiers,
                  trackTiers: trackTiers,
                  topNPerArtist: document.getElementById('gp-top-n').value ? parseInt(document.getElementById('gp-top-n').value) : null,
                  maxTracks: document.getElementById('gp-max-tracks').value ? parseInt(document.getElementById('gp-max-tracks').value) : null,
                  sortBy: document.getElementById('gp-sort-by').value,
                };
              }

              function runPreview() {
                var rules = getBuilderRules();
                var userId = document.getElementById('gp-preview-user').value;
                var url = '/api/playlists/global/preview?rules=' + encodeURIComponent(JSON.stringify(rules));
                if (userId) url += '&userId=' + encodeURIComponent(userId);
                fetch(url).then(function(r) { return r.json(); }).then(function(data) {
                  if (!data.ok) return;
                  if (data.forUser) {
                    document.getElementById('gp-prev-artists').textContent = data.forUser.artistCount;
                    document.getElementById('gp-prev-tracks').textContent = data.forUser.trackCount;
                    document.getElementById('gp-prev-avg-wrap').style.display = 'none';
                  } else if (data.average) {
                    document.getElementById('gp-prev-artists').textContent = data.average.artistCount;
                    document.getElementById('gp-prev-tracks').textContent = data.average.trackCount;
                    document.getElementById('gp-prev-avg-wrap').style.display = 'none';
                  }
                }).catch(function() {});
              }

              function schedulePreview() {
                clearTimeout(previewTimer);
                previewTimer = setTimeout(runPreview, 400);
              }

              document.querySelector('.gp-artist-tier-all').addEventListener('change', function() {
                if (this.checked) document.querySelectorAll('.gp-artist-tier').forEach(function(c) { c.checked = false; });
                schedulePreview();
              });
              document.querySelector('.gp-track-tier-all').addEventListener('change', function() {
                if (this.checked) document.querySelectorAll('.gp-track-tier').forEach(function(c) { c.checked = false; });
                schedulePreview();
              });
              document.querySelectorAll('.gp-artist-tier').forEach(function(c) {
                c.addEventListener('change', function() {
                  if (this.checked) document.querySelector('.gp-artist-tier-all').checked = false;
                  schedulePreview();
                });
              });
              document.querySelectorAll('.gp-track-tier').forEach(function(c) {
                c.addEventListener('change', function() {
                  if (this.checked) document.querySelector('.gp-track-tier-all').checked = false;
                  schedulePreview();
                });
              });
              ['gp-top-n','gp-max-tracks','gp-sort-by','gp-preview-user'].forEach(function(id) {
                var el = document.getElementById(id);
                if (el) el.addEventListener('change', schedulePreview);
                if (el && el.tagName === 'INPUT') el.addEventListener('input', schedulePreview);
              });

              document.querySelectorAll('.gp-delete-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                  var id = btn.dataset.gpId;
                  if (!confirm('Delete this global playlist? It will no longer be synced to Plex.')) return;
                  fetch('/api/playlists/global/' + id, {
                    method: 'DELETE',
                    headers: { 'X-CSRF-Token': _csrf },
                  }).then(function(r) { return r.json(); }).then(function(d) {
                    if (d.ok) btn.closest('.gp-card').remove();
                  });
                });
              });

              document.querySelectorAll('.gp-toggle').forEach(function(tog) {
                tog.addEventListener('change', function() {
                  var id = tog.dataset.gpId;
                  var label = tog.closest('.gp-toggle-wrap').querySelector('.gp-toggle-label');
                  fetch('/api/playlists/global/' + id, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': _csrf },
                    body: JSON.stringify({ enabled: tog.checked }),
                  }).then(function(r) { return r.json(); }).then(function(d) {
                    if (d.ok && label) label.textContent = tog.checked ? 'Enabled' : 'Disabled';
                  });
                });
              });

              document.getElementById('gp-create-btn').addEventListener('click', function() {
                var name = document.getElementById('gp-name').value.trim();
                var msg = document.getElementById('gp-create-msg');
                if (!name) { msg.textContent = 'Please enter a name.'; msg.className = 'gp-create-msg gp-msg--error'; return; }
                var rules = getBuilderRules();
                fetch('/api/playlists/global', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': _csrf },
                  body: JSON.stringify({ name: name, ...rules }),
                }).then(function(r) { return r.json(); }).then(function(d) {
                  if (!d.ok) { msg.textContent = d.error || 'Error creating playlist.'; msg.className = 'gp-create-msg gp-msg--error'; return; }
                  msg.textContent = 'Created! It will sync on the next job run.';
                  msg.className = 'gp-create-msg gp-msg--success';
                  var empty = document.getElementById('gp-empty');
                  if (empty) empty.remove();
                  var at = (d.playlist.rules?.artistTiers || []); var tt = (d.playlist.rules?.trackTiers || []);
                  var card = document.createElement('div');
                  card.className = 'settings-card gp-card'; card.dataset.gpId = d.playlist.id;
                  card.innerHTML = '<div class="gp-card-header"><span class="settings-card-title gp-card-name">' + d.playlist.name + '</span>'
                    + '<div class="gp-card-actions"><label class="gp-toggle-wrap"><input type="checkbox" class="gp-toggle" data-gp-id="' + d.playlist.id + '" checked /><span class="gp-toggle-label">Enabled</span></label>'
                    + '<button class="btn btn-sm btn-ghost-danger gp-delete-btn" data-gp-id="' + d.playlist.id + '">Delete</button></div></div>'
                    + '<div class="gp-card-rules"><span class="gp-rule-chip">Artists: ' + (at.length ? at.join(', ') : 'all') + '</span>'
                    + '<span class="gp-rule-chip">Tracks: ' + (tt.length ? tt.join(', ') : 'all') + '</span>'
                    + (d.playlist.rules?.topNPerArtist ? '<span class="gp-rule-chip">Top ' + d.playlist.rules.topNPerArtist + '/artist</span>' : '')
                    + (d.playlist.rules?.maxTracks ? '<span class="gp-rule-chip">Max ' + d.playlist.rules.maxTracks + ' tracks</span>' : '')
                    + '</div>';
                  document.getElementById('gp-list').appendChild(card);
                  card.querySelector('.gp-delete-btn').addEventListener('click', function() {
                    if (!confirm('Delete this global playlist?')) return;
                    fetch('/api/playlists/global/' + d.playlist.id, { method: 'DELETE', headers: { 'X-CSRF-Token': _csrf } })
                      .then(function(r) { return r.json(); }).then(function(r2) { if (r2.ok) card.remove(); });
                  });
                  card.querySelector('.gp-toggle').addEventListener('change', function() {
                    var t = card.querySelector('.gp-toggle'); var lbl = card.querySelector('.gp-toggle-label');
                    fetch('/api/playlists/global/' + d.playlist.id, { method: 'PUT', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': _csrf }, body: JSON.stringify({ enabled: t.checked }) })
                      .then(function(r) { return r.json(); }).then(function(r2) { if (r2.ok && lbl) lbl.textContent = t.checked ? 'Enabled' : 'Disabled'; });
                  });
                  document.getElementById('gp-name').value = '';
                });
              });

              runPreview();
            })();
            </script>
            <% } %>

          </div>
        </div>


        <%# ── Discovery ─────────────────────────────────────────────────────── %>
        <div class="settings-tab-panel<%= _tab === 'discovery' ? ' is-active' : '' %>" data-tab="discovery">
