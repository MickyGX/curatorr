              <button class="plex-modal-close" type="button" aria-label="Close">✕</button>
              <div class="plex-modal-header">
                <div class="plex-modal-title" id="settingsReleaseModalTitle">Release Notes</div>
                <div class="plex-modal-subtitle" id="settingsReleaseModalSubtitle">Changelog summary</div>
              </div>
              <div class="plex-modal-body settings-release-modal-body">
                <div class="plex-modal-scroll settings-release-modal-scroll">
                  <div class="settings-release-modal-summary" id="settingsReleaseModalSummary"></div>
                  <ul class="settings-release-modal-list" id="settingsReleaseModalList"></ul>
                </div>
              </div>
              <div class="plex-modal-footer">
                <a class="plex-modal-link" id="settingsReleaseModalLink" href="#" target="_blank" rel="noreferrer noopener">Full Release</a>
                <button class="plex-modal-link settings-release-modal-close" type="button">Close</button>
              </div>
            </div>
          </div>
        </div>

        <%# ── Appearance ────────────────────────────────────────────────────── %>
        <div class="settings-tab-panel<%= _tab === 'appearance' ? ' is-active' : '' %>" data-tab="appearance">
          <div class="dash-panel">
            <div class="settings-card settings-card--themes">
