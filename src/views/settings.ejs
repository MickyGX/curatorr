                  <span class="settings-toggle-slider" aria-hidden="true"></span>
                  <span class="settings-toggle-text">Trending Artists</span>
                </label>
                <input type="hidden" name="showTrendingTracks" value="" />
                <label class="settings-toggle">
                  <input type="checkbox" name="showTrendingTracks" value="1" <%= (config.discovery?.showTrendingTracks ?? true) ? 'checked' : '' %> />
                  <span class="settings-toggle-slider" aria-hidden="true"></span>
                  <span class="settings-toggle-text">Trending Tracks</span>
                </label>
                <input type="hidden" name="showSimilarArtists" value="" />
                <label class="settings-toggle">
                  <input type="checkbox" name="showSimilarArtists" value="1" <%= (config.discovery?.showSimilarArtists ?? true) ? 'checked' : '' %> />
                  <span class="settings-toggle-slider" aria-hidden="true"></span>
                  <span class="settings-toggle-text">Because You Like… (similar artists)</span>
                </label>
              </div>
              <button class="primary-button" type="submit">Save discovery settings</button>
            </form>
          </div>
        </div>

        <%# ── Users ────────────────────────────────────────────────────────── %>
        <div class="settings-tab-panel<%= _tab === 'users' ? ' is-active' : '' %>" data-tab="users">
          <div class="dash-panel">
            <div class="settings-form settings-users">
              <%
                const _users = Array.isArray(users) ? users : [];
                const usersQueryError = _tab === 'users' ? String(error || '') : '';
                const localUsersResultMap = {
                  '1': 'Curatorr user settings updated.',
                };
                const usersQuerySuccess = _tab === 'users' ? String(success || '') : '';
                const localUsersNote = usersQueryError || localUsersResultMap[usersQuerySuccess] || 'Create local Curatorr users and manage access roles.';
              %>
              <div class="settings-card">
                <div class="settings-card-title">Curatorr Users</div>
                <div class="settings-card-sub">Local accounts can sign in without Plex and use role-based access.</div>
                <div class="settings-users-actions">
                  <span class="settings-users-note<%= usersQueryError ? ' settings-users-note--error' : '' %>"><%= localUsersNote %></span>
                </div>
                <form method="post" action="/settings/local-users/add" class="settings-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <label class="field">
                    <span>Username</span>
                    <input type="text" name="username" placeholder="localuser" required />
                  </label>
                  <label class="field">
                    <span>Email (optional)</span>
                    <input type="email" name="email" placeholder="user@example.com" />
                  </label>
                  <label class="field">
                    <span>Password</span>
                    <input type="password" name="password" placeholder="Min 12 with upper/lower/number/symbol" minlength="12" required />
                  </label>
                  <label class="field">
                    <span>Role</span>
                    <select class="settings-select" name="role">
                      <option value="guest">Guest</option>
                      <option value="user" selected>User</option>
                      <option value="power-user">Power user</option>
                      <option value="co-admin">Co-admin</option>
                      <option value="admin">Admin</option>
                      <option value="disabled">Disabled</option>
                    </select>
                  </label>
                  <button class="primary-button" type="submit">Add Curatorr user</button>
                </form>
                <div class="settings-users-table">
                  <div class="settings-users-row settings-users-row--local settings-users-head">
                    <div class="settings-users-head-cell settings-users-col-user">
                      <img class="settings-head-icon" src="/icons/name.svg" alt="" />
                      <span>User</span>
                    </div>
                    <div class="settings-users-head-cell settings-users-col-email">
                      <span>Email</span>
                    </div>
                    <div class="settings-users-head-cell settings-users-col-last">
                      <span>Last Curatorr login</span>
                    </div>
                    <div class="settings-users-head-cell settings-users-col-role">
                      <img class="settings-head-icon" src="/icons/role.svg" alt="" />
                      <span>Role</span>
                    </div>
                    <div class="settings-users-head-cell settings-users-head-cell--delete settings-users-col-delete">
                      <img class="settings-head-icon" src="/icons/delete.svg" alt="" />
                      <span>Delete</span>
                    </div>
                  </div>
                  <% if (_users.length) { %>
                    <% _users.forEach(function(localUser) { %>
                      <%
                        const localLogin = localUser.lastCuratorrLogin && !Number.isNaN(Date.parse(localUser.lastCuratorrLogin))
                          ? new Date(localUser.lastCuratorrLogin).toLocaleString()
                          : '—';
                      %>
                      <div class="settings-users-row settings-users-row--local">
                        <div class="settings-users-name settings-users-col-user" data-label="User">
                          <%= localUser.username %>
                          <% if (localUser.isOwnerAccount) { %>
                            <span class="settings-users-locked">Setup admin</span>
                          <% } else if (localUser.isCurrentSessionUser) { %>
                            <span class="settings-users-locked">Current session</span>
                          <% } %>
                        </div>
                        <div class="settings-users-login settings-users-col-email" data-label="Email"><%= localUser.email || '—' %></div>
                        <div class="settings-users-login settings-users-col-last" data-label="Last Curatorr login" title="<%= localUser.lastCuratorrLogin || '' %>"><%= localLogin %></div>
                        <div class="settings-users-role settings-users-col-role" data-label="Role">
                          <form method="post" action="/settings/local-users/role" class="settings-role-inline-form">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                            <input type="hidden" name="username" value="<%= localUser.username %>" />
                            <select name="role">
                              <option value="guest" <%= localUser.role === 'guest' ? 'selected' : '' %>>Guest</option>
                              <option value="user" <%= localUser.role === 'user' ? 'selected' : '' %>>User</option>
                              <option value="power-user" <%= localUser.role === 'power-user' ? 'selected' : '' %>>Power user</option>
                              <option value="co-admin" <%= localUser.role === 'co-admin' ? 'selected' : '' %>>Co-admin</option>
                              <option value="admin" <%= localUser.role === 'admin' ? 'selected' : '' %>>Admin</option>
                              <option value="disabled" <%= localUser.role === 'disabled' ? 'selected' : '' %>>Disabled</option>
                            </select>
                            <button class="primary-button" type="submit">Save</button>
                          </form>
                        </div>
                        <div class="settings-users-delete settings-users-col-delete" data-label="Delete">
                          <form
                            method="post"
                            action="/settings/local-users/remove"
                            class="local-user-delete-form"
                            onsubmit="return confirm('Delete this Curatorr user? This cannot be undone.');"
                          >
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                            <input type="hidden" name="username" value="<%= localUser.username %>" />
                            <button
                              class="local-user-delete"
                              type="submit"
                              <%= localUser.canDelete ? '' : 'disabled' %>
                              title="<%= localUser.isOwnerAccount ? 'Setup admin account cannot be deleted' : (localUser.isCurrentSessionUser ? 'You cannot delete your current session account' : 'Delete Curatorr user') %>"
                              aria-label="Delete Curatorr user"
                            >
                              <img src="/icons/delete.svg" alt="" />
                            </button>
                          </form>
                        </div>
                      </div>
                    <% }) %>
                  <% } else { %>
                    <div class="settings-users-row settings-users-row--local">
                      <div class="settings-users-login settings-users-col-user">No local Curatorr users found.</div>
                      <div class="settings-users-login settings-users-col-email">—</div>
                      <div class="settings-users-login settings-users-col-last">—</div>
                      <div class="settings-users-login settings-users-col-role">—</div>
                      <div class="settings-users-login settings-users-col-delete">—</div>
                    </div>
                  <% } %>
                </div>
              </div>

              <div class="settings-card">
                <div class="settings-card-title">Plex Users</div>
                <div class="settings-card-sub">Pull users from Plex and assign Curatorr roles.</div>
                <div class="settings-users-actions">
                  <button class="primary-button" type="button" id="fetchPlexUsersBtn">Fetch users</button>
                  <button class="primary-button" type="button" id="savePlexRolesBtn" disabled>Save roles</button>
                  <span class="settings-users-note" id="plexUsersNote">Pull the user list from Plex to assign roles.</span>
                </div>
                <div class="settings-users-table">
                  <div class="settings-users-row settings-users-head">
                    <div class="settings-users-head-cell settings-users-sort" data-sort-key="name" role="button" tabindex="0">
                      <img class="settings-head-icon" src="/icons/name.svg" alt="" />
                      <span>Name</span>
                    </div>
                    <div class="settings-users-head-cell settings-users-sort" data-sort-key="plex" role="button" tabindex="0">
                      <span>Last seen (Plex)</span>
                    </div>
                    <div class="settings-users-head-cell settings-users-sort" data-sort-key="curatorr" role="button" tabindex="0">
                      <span>Last Curatorr login</span>
                    </div>
                    <div class="settings-users-head-cell settings-users-sort" data-sort-key="role" role="button" tabindex="0">
                      <img class="settings-head-icon" src="/icons/role.svg" alt="" />
                      <span>Role</span>
                    </div>
                  </div>
                  <div id="plexUsersBody"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <%# ── Logs ─────────────────────────────────────────────────────────── %>
        <div class="settings-tab-panel<%= _tab === 'logs' ? ' is-active' : '' %>" data-tab="logs">
          <div class="dash-panel">
            <form method="post" action="/settings/logs" class="settings-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div class="settings-card">
                <div class="settings-card-title">Retention</div>
                <div class="settings-card-sub">Logs are stored on disk and pruned by these limits.</div>
                <div class="settings-log-row">
                  <label class="field">
                    <span>Max Entries</span>
                    <input type="number" min="50" max="5000" step="50" name="log_max_entries" value="<%= logSettings?.maxEntries || 500 %>" />
                  </label>
                  <label class="field">
                    <span>Max Days</span>
                    <input type="number" min="1" max="365" step="1" name="log_max_days" value="<%= logSettings?.maxDays || 30 %>" />
                  </label>
                  <label class="field">
                    <span>Visible Rows</span>
                    <input type="number" min="3" max="100" step="1" name="log_visible_rows" value="<%= logSettings?.visibleRows || 25 %>" />
                  </label>
                  <button class="primary-button" type="submit">Save log settings</button>
                </div>
              </div>
            </form>
          </div>

          <div class="dash-panel">
            <div class="settings-card">
              <div class="settings-card-title">Activity</div>
              <div class="settings-card-sub">Use this to trace playlist syncs, wizard events, and Lidarr automation decisions.</div>
              <div class="log-toolbar">
                <div class="log-filter">
                  <span class="log-filter-label">App</span>
                  <select class="settings-select" id="settingsLogApp">
                    <option value="">All</option>
                    <option value="system">System</option>
                    <option value="settings">Settings</option>
                    <option value="wizard">Wizard</option>
                    <option value="plex">Plex</option>
                    <option value="tautulli">Tautulli</option>
                    <option value="webhook">Webhook</option>
                    <option value="music">Music</option>
                    <option value="playlist">Playlist</option>
                    <option value="recommendations">Recommendations</option>
                    <option value="lidarr">Lidarr</option>
                    <option value="client">Client</option>
                  </select>
                </div>
                <div class="log-filter">
                  <span class="log-filter-label">Level</span>
                  <select class="settings-select" id="settingsLogLevel">
                    <option value="">All</option>
                    <option value="info">Info</option>
                    <option value="warn">Warn</option>
                    <option value="error">Error</option>
                  </select>
                </div>
                <button class="primary-button log-refresh" type="button" id="settingsLogRefresh">Refresh</button>
                <span class="log-status" id="settingsLogStatus">Loading...</span>
              </div>
              <div class="log-list" id="settingsLogList" style="--log-visible-rows:<%= logSettings?.visibleRows || 25 %>"></div>
            </div>
          </div>
        </div>

        <%# ── About ─────────────────────────────────────────────────────────── %>
        <div class="settings-tab-panel<%= _tab === 'about' ? ' is-active' : '' %>" data-tab="about">
          <div class="dash-panel">
            <div class="settings-card">
