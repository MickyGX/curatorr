                  <span class="cur-mode-meta">Night mode</span>
                </button>
                <button class="cur-mode-card" type="button" data-mode="day" id="modeDay">
                  <span class="cur-mode-icon">☀️</span>
                  <span class="cur-mode-name">Light</span>
                  <span class="cur-mode-meta">Day mode</span>
                </button>
