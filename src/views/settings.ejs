                  <span class="theme-preset-chip theme-preset-chip--custom" data-custom-chip style="--theme-color:#8b5cf6">
                    <input class="theme-chip-picker" id="customThemeColor" type="color" value="#8b5cf6" aria-label="Choose custom colour" />
                  </span>
                  <span class="theme-preset-name">Custom</span>
