                <label class="settings-toggle theme-option" id="optBgMotion">
                  <input type="checkbox" id="chkBgMotion" />
                  <span class="settings-toggle-slider" aria-hidden="true"></span>
                  <span class="theme-option-copy">
                    <strong>Animated background</strong>
                    <small>Moving star field in the background.</small>
                  </span>
                </label>
