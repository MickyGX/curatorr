                <label class="settings-toggle theme-option" id="optSidebarInvert">
                  <input type="checkbox" id="chkSidebarInvert" />
                  <span class="settings-toggle-slider" aria-hidden="true"></span>
                  <span class="theme-option-copy">
                    <strong>Invert sidebar colours</strong>
                    <small>Swap sidebar dark/theme emphasis.</small>
                  </span>
                </label>
                <label class="settings-toggle theme-option" id="optSquareCorners">
                  <input type="checkbox" id="chkSquareCorners" />
                  <span class="settings-toggle-slider" aria-hidden="true"></span>
                  <span class="theme-option-copy">
                    <strong>Square corners</strong>
                    <small>Remove rounded corners across the UI.</small>
                  </span>
                </label>
                <label class="settings-toggle theme-option" id="optBgMotion">
                  <input type="checkbox" id="chkBgMotion" />
                  <span class="settings-toggle-slider" aria-hidden="true"></span>
                  <span class="theme-option-copy">
                    <strong>Animated background</strong>
                    <small>Moving star field in the background.</small>
                  </span>
                </label>
                <label class="settings-toggle theme-option" id="optHideScrollbars">
                  <input type="checkbox" id="chkHideScrollbars" />
                  <span class="settings-toggle-slider" aria-hidden="true"></span>
                  <span class="theme-option-copy">
                    <strong>Hide scrollbars</strong>
                    <small>Hide scrollbar rails while keeping scroll behaviour.</small>
                  </span>
                </label>
              </div>
            </div>
          </div>
        </div>

        <%# ── Jobs (admin only) ─────────────────────────────────────────────── %>
        <% if (actualRole === 'admin') { %>
        <div class="settings-tab-panel<%= _tab === 'jobs' ? ' is-active' : '' %>" data-tab="jobs">
          <div class="dash-panel">
            <div class="settings-card">
              <div class="settings-card-title">Scheduled Jobs</div>
              <div class="settings-card-sub">Configure and manually trigger system-wide background jobs. Changes take effect immediately without restart.</div>
            </div>
            <form method="post" action="/settings/jobs" class="settings-form" id="jobsSettingsForm">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <%
                const _jobsCfg = config.jobs || {};
                const _jobIds = Object.keys(jobDefs || {});
              %>
              <% for (const _jid of _jobIds) { %>
              <%
                const _jdef = jobDefs[_jid];
                const _jcfg = _jobsCfg[_jid] || {};
                const _jstat = jobStatus[_jid] || {};
                const _jEnabled = _jcfg.enabled !== false;
                const _jInterval = _jcfg.intervalMinutes || _jdef.defaultIntervalMinutes;
                const _jStatus = _jstat.status || 'idle';
                const _jLastRun = _jstat.lastRunAt;
                const _jMsg = _jstat.message || '';
              %>
              <div class="settings-card settings-job-card" data-job-id="<%= _jid %>">
                <div class="settings-job-card-header">
                  <div class="settings-job-card-meta">
                    <div class="settings-card-title" style="margin-bottom:4px"><%= _jdef.label %></div>
                    <div class="settings-card-sub" style="margin-bottom:0"><%= _jdef.description %></div>
                  </div>
                  <div class="settings-job-card-actions">
                    <span class="settings-job-status-badge settings-job-status-badge--<%= _jStatus %>" data-job-status="<%= _jid %>"><%= _jStatus %></span>
                    <button type="button" class="settings-btn settings-job-run-btn" data-job-id="<%= _jid %>">Run Now</button>
                  </div>
                </div>
                <div class="settings-job-last-run" data-job-last-run="<%= _jid %>">
                  <% if (_jLastRun) { %>
                    Last run: <span class="settings-job-time" data-ts="<%= _jLastRun %>"></span>
                    <% if (_jMsg) { %><span class="settings-job-msg"> — <%= _jMsg %></span><% } %>
                  <% } else { %>
                    Never run
                  <% } %>
                </div>
                <div class="settings-job-controls">
                  <label class="field" style="flex:0 0 auto;min-width:0">
                    <span>Interval (minutes)</span>
                    <input type="number" name="<%= _jid %>_interval" value="<%= _jInterval %>" min="1" max="1440" style="width:90px" />
                  </label>
                  <label class="settings-smart-toggle-field" style="align-self:flex-end;padding-bottom:2px">
                    <span class="settings-smart-toggle-field-title">Enabled</span>
                    <span class="settings-toggle">
                      <input id="job_enabled_<%= _jid %>" type="checkbox" name="<%= _jid %>_enabled" value="1" <%= _jEnabled ? 'checked' : '' %> />
                      <span class="settings-toggle-slider" aria-hidden="true"></span>
                    </span>
                  </label>
                </div>
              </div>
              <% } %>
              <div style="margin-top:4px">
                <button type="submit" class="settings-btn settings-btn--primary">Save Job Settings</button>
              </div>
            </form>

            <%# ── Playlist maintenance ── %>
            <div class="settings-card" style="margin-top:20px">
              <div class="settings-card-title">Playlist Account Maintenance</div>
              <div class="settings-card-sub">
                If generated playlists (Crescive, Curative, Daily Mix) appear under the wrong Plex account in Plexamp,
                use this to delete the misowned copies from Plex and re-register them so the next sync recreates
                each playlist under the correct user's account.
              </div>
              <div style="margin-top:14px; display:flex; align-items:center; gap:12px">
                <button type="button" class="settings-btn settings-btn--primary" id="reassignPlaylistsBtn" onclick="reassignPlaylists()">Reassign All Playlists</button>
                <span id="reassignPlaylistsStatus" class="settings-sub-label"></span>
              </div>
            </div>
          </div>
        </div>
        <% } %>

      </div>
    </section>
  </div>

  <script src="/sidebar.js?v=<%= assetVersion %>"></script>
  <script src="/user-menu.js?v=<%= assetVersion %>"></script>
  <script src="/version-badge.js?v=<%= assetVersion %>"></script>
  <script src="/brand-menu.js?v=<%= assetVersion %>"></script>
  <script src="/starfield-3d.js"></script>
  <script>
  // ── Tab switching ──────────────────────────────────────────────────────────
  (function() {
    var tabBtns = Array.from(document.querySelectorAll('.settings-tab-btn'));
    var tabPanels = Array.from(document.querySelectorAll('.settings-tab-panel'));
    function activateTab(id) {
      tabBtns.forEach(function(b) { b.classList.toggle('is-active', b.dataset.tab === id); });
      tabPanels.forEach(function(p) { p.classList.toggle('is-active', p.dataset.tab === id); });
      try { localStorage.setItem('curatorr-settings-tab', id); } catch(e) {}
    }
    tabBtns.forEach(function(btn) {
      btn.addEventListener('click', function() { activateTab(btn.dataset.tab); });
    });
    var serverTab = '<%= _tab %>';
    var savedTab = '';
    try { savedTab = localStorage.getItem('curatorr-settings-tab') || ''; } catch(e) {}
    var initialTab = serverTab || savedTab || 'general';
    if (!tabBtns.some(function(btn) { return btn.dataset.tab === initialTab; })) initialTab = 'general';
    activateTab(initialTab);
  })();

  // ── Jobs ──────────────────────────────────────────────────────────────────
  (function() {
    function fmtRelTime(ts) {
      if (!ts) return 'Never';
      var diff = Math.floor((Date.now() - ts) / 1000);
      if (diff < 60) return 'just now';
      if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
      if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
      return Math.floor(diff / 86400) + 'd ago';
    }

    function applyStatus(data) {
      Object.keys(data).forEach(function(jobId) {
        var s = data[jobId];
        var badge = document.querySelector('[data-job-status="' + jobId + '"]');
        var lastRunEl = document.querySelector('[data-job-last-run="' + jobId + '"]');
        if (badge) {
          badge.textContent = s.status;
          badge.className = 'settings-job-status-badge settings-job-status-badge--' + s.status;
        }
        if (lastRunEl && s.lastRunAt) {
          var msg = s.message ? ' \u2014 ' + s.message : '';
          lastRunEl.innerHTML = 'Last run: <span class="settings-job-time">' + fmtRelTime(s.lastRunAt) + '</span>' + (msg ? '<span class="settings-job-msg">' + msg + '</span>' : '');
        } else if (lastRunEl && !s.lastRunAt) {
          lastRunEl.textContent = 'Never run';
        }
      });
    }

    // Relative timestamps on page load
    document.querySelectorAll('.settings-job-time[data-ts]').forEach(function(el) {
      el.textContent = fmtRelTime(Number(el.dataset.ts));
    });

    // Poll status while any job is running
    var pollTimer = null;
    function startPolling() {
      if (pollTimer) return;
      pollTimer = setInterval(function() {
        fetch('/api/jobs/status').then(function(r) { return r.json(); }).then(function(data) {
          applyStatus(data);
          var anyRunning = Object.values(data).some(function(s) { return s.status === 'running'; });
          if (!anyRunning) { clearInterval(pollTimer); pollTimer = null; }
        }).catch(function() {});
      }, 2000);
    }

    // Run Now buttons
    document.querySelectorAll('.settings-job-run-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var jobId = btn.dataset.jobId;
        var badge = document.querySelector('[data-job-status="' + jobId + '"]');
        if (badge) { badge.textContent = 'running'; badge.className = 'settings-job-status-badge settings-job-status-badge--running'; }
        fetch('/api/jobs/' + jobId + '/run', { method: 'POST', headers: { 'X-CSRF-Token': document.querySelector('[name=_csrf]')?.value || '' } })
          .then(function() { startPolling(); })
          .catch(function() {});
      });
    });
  })();

  function reassignPlaylists() {
    var btn = document.getElementById('reassignPlaylistsBtn');
    var status = document.getElementById('reassignPlaylistsStatus');
    btn.disabled = true;
    status.textContent = 'Deleting misowned playlists from Plex…';
    fetch('/api/admin/playlists/reassign', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('[name=_csrf]')?.value || '' },
    }).then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.ok) throw new Error(data.error || 'Failed');
        if (data.reassigned > 0) {
          status.textContent = data.reassigned + ' playlist(s) reassigned. Trigger a Smart Playlist Sync job to recreate them under each user\'s account.';
        } else {
          status.textContent = 'No playlists found to reassign.';
        }
        if (data.errors && data.errors.length) {
          status.textContent += ' Errors: ' + data.errors.join(', ');
        }
        btn.disabled = false;
      })
      .catch(function(err) {
        status.textContent = 'Error: ' + (err.message || 'Unknown');
        btn.disabled = false;
      });
  }

  // ── Logs ──────────────────────────────────────────────────────────────────
  (function() {
    var settingsLogList = document.getElementById('settingsLogList');
    var settingsLogStatus = document.getElementById('settingsLogStatus');
    var settingsLogRefresh = document.getElementById('settingsLogRefresh');
    var settingsLogApp = document.getElementById('settingsLogApp');
    var settingsLogLevel = document.getElementById('settingsLogLevel');
    var logAppNames = {
      system: 'System',
      settings: 'Settings',
      wizard: 'Wizard',
      plex: 'Plex',
      tautulli: 'Tautulli',
      webhook: 'Webhook',
      music: 'Music',
      playlist: 'Playlist',
      recommendations: 'Recommendations',
      lidarr: 'Lidarr',
      client: 'Client'
    };
    var settingsLogs = [];

    function escapeLogHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function formatLogTime(value) {
      var date = value ? new Date(value) : null;
      if (!date || Number.isNaN(date.getTime())) return '';
      return date.toLocaleString();
    }

    function renderSettingsLogs() {
      if (!settingsLogList) return;
      var appFilter = String(settingsLogApp && settingsLogApp.value || '').trim().toLowerCase();
      var levelFilter = String(settingsLogLevel && settingsLogLevel.value || '').trim().toLowerCase();
      var filtered = settingsLogs.filter(function(entry) {
        if (appFilter && String(entry.app || '').toLowerCase() !== appFilter) return false;
        if (levelFilter && String(entry.level || '').toLowerCase() !== levelFilter) return false;
        return true;
      });
      if (!filtered.length) {
        settingsLogList.innerHTML = '<div class="log-empty">No logs yet.</div>';
        return;
      }
      settingsLogList.innerHTML = filtered.map(function(entry) {
        var appId = String(entry.app || 'system').toLowerCase();
        var appName = logAppNames[appId] || appId;
        var level = String(entry.level || 'info').toLowerCase();
        var action = String(entry.action || 'event');
        var message = String(entry.message || '');
        var meta = entry.meta && typeof entry.meta === 'object'
          ? '<div class="log-meta">' + escapeLogHtml(JSON.stringify(entry.meta)) + '</div>'
          : '';
        return '' +
          '<div class="log-row log-row--' + escapeLogHtml(level) + '" data-app="' + escapeLogHtml(appId) + '">' +
            '<div class="log-time">' + escapeLogHtml(formatLogTime(entry.ts)) + '</div>' +
            '<div class="log-message">' +
              '<div class="log-title">' +
                '<span class="log-app-pill" data-app="' + escapeLogHtml(appId) + '">' + escapeLogHtml(appName) + '</span>' +
                escapeLogHtml(action) +
              '</div>' +
              '<div class="log-text">' + escapeLogHtml(message) + '</div>' +
              meta +
            '</div>' +
          '</div>';
      }).join('');
    }

    async function loadSettingsLogs() {
      if (!settingsLogList || !settingsLogStatus) return;
      settingsLogStatus.textContent = 'Loading...';
      var params = new URLSearchParams();
      params.set('limit', '250');
      if (settingsLogApp && settingsLogApp.value) params.set('appId', settingsLogApp.value);
      if (settingsLogLevel && settingsLogLevel.value) params.set('level', settingsLogLevel.value);
      try {
        var response = await fetch('/api/logs?' + params.toString());
        var payload = response.ok ? await response.json() : { items: [] };
        settingsLogs = Array.isArray(payload.items) ? payload.items : [];
        renderSettingsLogs();
        settingsLogStatus.textContent = new Date().toLocaleTimeString();
      } catch (_err) {
        settingsLogStatus.textContent = 'Failed to load logs';
      }
    }

    if (settingsLogRefresh) settingsLogRefresh.addEventListener('click', loadSettingsLogs);
    if (settingsLogApp) settingsLogApp.addEventListener('change', loadSettingsLogs);
    if (settingsLogLevel) settingsLogLevel.addEventListener('change', loadSettingsLogs);
    loadSettingsLogs();
  })();

  // ── About ─────────────────────────────────────────────────────────────────
  (function() {
    try {
      var settingsAboutVersion = document.getElementById('settingsAboutVersion');
      var settingsAboutLatest = document.getElementById('settingsAboutLatest');
      var settingsAboutVersionState = document.getElementById('settingsAboutVersionState');
      var settingsAboutTimeZone = document.getElementById('settingsAboutTimeZone');
      var settingsReleaseModalBackdrop = document.getElementById('settingsReleaseModalBackdrop');
      var settingsReleaseModalTitle = document.getElementById('settingsReleaseModalTitle');
      var settingsReleaseModalSubtitle = document.getElementById('settingsReleaseModalSubtitle');
      var settingsReleaseModalSummary = document.getElementById('settingsReleaseModalSummary');
      var settingsReleaseModalList = document.getElementById('settingsReleaseModalList');
      var settingsReleaseModalLink = document.getElementById('settingsReleaseModalLink');
      var settingsReleaseOpenButtons = Array.from(document.querySelectorAll('.settings-release-open'));
      var releaseModalCloseButtons = settingsReleaseModalBackdrop
        ? Array.from(settingsReleaseModalBackdrop.querySelectorAll('.settings-release-modal-close, .plex-modal-close'))
        : [];
      var aboutReleaseEntriesRaw = <%- safeJson(aboutReleases || []) %>;
      var aboutReleaseEntries = Array.isArray(aboutReleaseEntriesRaw) ? aboutReleaseEntriesRaw : [];

      if (settingsReleaseModalBackdrop && settingsReleaseModalBackdrop.parentElement !== document.body) {
        document.body.appendChild(settingsReleaseModalBackdrop);
      }

      var normalizeVersionTag = function(value) {
        var raw = String(value || '').trim();
        if (!raw) return '';
        return raw.startsWith('v') ? raw : ('v' + raw);
      };
      var escapeHtml = function(value) {
        return String(value || '').replace(/[&<>\"']/g, function(char) {
          return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' })[char];
        });
      };
      var parseHighlight = function(value) {
        var raw = String(value || '').trim();
        if (!raw) return null;
        var match = raw.match(/^([A-Za-z][A-Za-z\\s]+):\\s*(.+)$/);
        if (!match) return { section: 'Update', detail: raw };
        return {
          section: String(match[1] || '').trim() || 'Update',
          detail: String(match[2] || '').trim() || raw,
        };
      };
      var formatRelativeTime = function(value) {
        var date = value ? new Date(value) : null;
        if (!date || Number.isNaN(date.getTime())) return 'Recently';
        var seconds = Math.max(0, Math.floor((Date.now() - date.getTime()) / 1000));
        if (seconds < 60) return 'Just now';
        var minutes = Math.floor(seconds / 60);
        if (minutes < 60) return minutes + ' minute' + (minutes === 1 ? '' : 's') + ' ago';
        var hours = Math.floor(minutes / 60);
        if (hours < 24) return hours + ' hour' + (hours === 1 ? '' : 's') + ' ago';
        var days = Math.floor(hours / 24);
        if (days < 30) return days + ' day' + (days === 1 ? '' : 's') + ' ago';
        var months = Math.floor(days / 30);
        if (months < 12) return months + ' month' + (months === 1 ? '' : 's') + ' ago';
        var years = Math.floor(months / 12);
        return years + ' year' + (years === 1 ? '' : 's') + ' ago';
      };
      var updateReleaseRelativeTimes = function() {
        document.querySelectorAll('[data-release-published-at]').forEach(function(node) {
          var publishedAt = String(node.getAttribute('data-release-published-at') || '').trim();
          node.textContent = formatRelativeTime(publishedAt);
        });
      };
      var setVersionState = function(text, tone) {
        if (!settingsAboutVersionState) return;
        settingsAboutVersionState.textContent = String(text || '').trim();
        settingsAboutVersionState.classList.remove('settings-about-pill--ok', 'settings-about-pill--warn');
        if (tone === 'ok') settingsAboutVersionState.classList.add('settings-about-pill--ok');
        if (tone === 'warn') settingsAboutVersionState.classList.add('settings-about-pill--warn');
      };
      var closeReleaseModal = function() {
        if (!settingsReleaseModalBackdrop) return;
        settingsReleaseModalBackdrop.classList.add('plex-hidden');
        window.removeEventListener('keydown', onReleaseModalKeydown);
      };
      var onReleaseModalKeydown = function(event) {
        if (event.key === 'Escape') closeReleaseModal();
      };
      var openReleaseModal = function(release) {
        if (!settingsReleaseModalBackdrop || !release) return;
        var releaseTag = normalizeVersionTag(release.tag || 'Release');
        var subtitle = release.publishedAt ? formatRelativeTime(release.publishedAt) : 'Changelog summary';
        var highlights = (Array.isArray(release.highlights) ? release.highlights : [])
          .map(parseHighlight)
          .filter(Boolean)
          .slice(0, 3);
        var summary = String(release.summary || '').trim()
          || (highlights[0] ? highlights[0].detail : 'Release notes are available.');
        if (settingsReleaseModalTitle) settingsReleaseModalTitle.textContent = 'Release ' + releaseTag;
        if (settingsReleaseModalSubtitle) settingsReleaseModalSubtitle.textContent = subtitle;
        if (settingsReleaseModalSummary) settingsReleaseModalSummary.textContent = summary;
        if (settingsReleaseModalList) {
          settingsReleaseModalList.innerHTML = highlights.length
            ? highlights.map(function(item) {
              return '<li class="settings-release-modal-item">'
                + '<span class="settings-release-modal-tag">' + escapeHtml(item.section) + '</span>'
                + '<span class="settings-release-modal-text">' + escapeHtml(item.detail) + '</span>'
                + '</li>';
            }).join('')
            : '<li class="settings-release-modal-item"><span class="settings-release-modal-text">No highlight entries were found for this release.</span></li>';
        }
        if (settingsReleaseModalLink) {
          settingsReleaseModalLink.href = String(release.releaseNotesUrl || '#').trim() || '#';
        }
        settingsReleaseModalBackdrop.classList.remove('plex-hidden');
        window.addEventListener('keydown', onReleaseModalKeydown);
      };

      settingsReleaseOpenButtons.forEach(function(button) {
        button.addEventListener('click', function() {
          var index = Number(button.dataset.releaseIndex);
          if (!Number.isFinite(index)) return;
          var release = aboutReleaseEntries[index];
          if (!release) return;
          openReleaseModal(release);
        });
      });
      if (settingsReleaseModalBackdrop) {
        settingsReleaseModalBackdrop.addEventListener('click', function(event) {
          if (event.target === settingsReleaseModalBackdrop) closeReleaseModal();
        });
      }
      releaseModalCloseButtons.forEach(function(button) {
        button.addEventListener('click', closeReleaseModal);
      });

      updateReleaseRelativeTimes();
      if (settingsAboutTimeZone) {
        var tz = String(Intl.DateTimeFormat().resolvedOptions().timeZone || '').trim();
        settingsAboutTimeZone.textContent = tz || 'Unknown';
      }

      var fallbackCurrent = normalizeVersionTag(settingsAboutVersion && settingsAboutVersion.textContent || '');
      var fallbackLatest = normalizeVersionTag(settingsAboutLatest && settingsAboutLatest.textContent || '');
      if (fallbackLatest && settingsAboutLatest) settingsAboutLatest.textContent = fallbackLatest;
      if (fallbackCurrent && settingsAboutVersion) settingsAboutVersion.textContent = fallbackCurrent;
      if (fallbackCurrent && fallbackLatest && fallbackCurrent === fallbackLatest) {
        setVersionState('Up to Date', 'ok');
      } else if (fallbackLatest) {
        setVersionState('Update Available', 'warn');
      } else {
        setVersionState('Unknown', '');
      }

      fetch('/api/version')
        .then(function(response) { return response.ok ? response.json() : null; })
        .then(function(payload) {
          if (!payload) return;
          var current = normalizeVersionTag(payload.current || fallbackCurrent);
          var latest = normalizeVersionTag(payload.latest || fallbackLatest);
          if (settingsAboutVersion && current) settingsAboutVersion.textContent = current;
          if (settingsAboutLatest && latest) settingsAboutLatest.textContent = latest;
          if (current && latest && current === latest) {
            setVersionState('Up to Date', 'ok');
          } else if (current && latest && current !== latest) {
            setVersionState('Update Available', 'warn');
          } else {
            setVersionState('Version Info', '');
          }
        })
        .catch(function() {
          setVersionState('Version Info', '');
        });
    } catch (err) {
      console.error('[Curatorr] About settings init failed', err);
    }
  })();

  // ── Appearance ─────────────────────────────────────────────────────────────
  (function() {
    var BRAND_COLORS = {
      curatorr: { hex:'#8b5cf6', r:139, g:92,  b:246 },
      pulsarr:  { hex:'#1cc6c2', r:28,  g:198, b:194 },
      plex:     { hex:'#f9ad2f', r:249, g:173, b:47  },
      lidarr:   { hex:'#53b86a', r:83,  g:184, b:106 },
    };

    function mix(base, target, amt) { return Math.round(base + (target - base) * amt); }
    function toHex(v) { return Math.max(0, Math.min(255, v)).toString(16).padStart(2, '0'); }

    function applyBrandTheme(theme, customHex) {
      var hex, r, g, b;
      if (theme === 'custom') {
        hex = customHex || '#8b5cf6';
        r = parseInt(hex.slice(1,3), 16);
        g = parseInt(hex.slice(3,5), 16);
        b = parseInt(hex.slice(5,7), 16);
      } else {
        var c = BRAND_COLORS[theme] || BRAND_COLORS.curatorr;
        hex = c.hex; r = c.r; g = c.g; b = c.b;
      }
      var dark  = '#' + toHex(mix(r,0,.4))   + toHex(mix(g,0,.4))   + toHex(mix(b,0,.4));
      var start = '#' + toHex(mix(r,255,.35)) + toHex(mix(g,255,.35))+ toHex(mix(b,255,.35));
      var end   = '#' + toHex(mix(r,0,.2))    + toHex(mix(g,0,.2))   + toHex(mix(b,0,.2));
      var lum = 0.2126*Math.pow(r/255,2.2) + 0.7152*Math.pow(g/255,2.2) + 0.0722*Math.pow(b/255,2.2);
      var onBrand = (1.05/(lum+0.05)) >= ((lum+0.05)/0.05) ? '#ffffff' : '#081013';
      var root = document.documentElement;
      root.style.setProperty('--teal', hex);
      root.style.setProperty('--teal-dark', dark);
      root.style.setProperty('--brand-rgb', r+','+g+','+b);
      root.style.setProperty('--brand-btn-start', start);
      root.style.setProperty('--brand-btn-mid', hex);
      root.style.setProperty('--brand-btn-end', end);
      root.style.setProperty('--brand-btn-shadow', mix(r,0,.28)+','+mix(g,0,.28)+','+mix(b,0,.28));
      root.style.setProperty('--on-brand', onBrand);
    }

    // Read current state
    var root = document.documentElement;
    var storedTheme    = '';
    var storedBrand    = '';
    var storedCustom   = '';
    var storedInvert   = false;
    var storedSquare   = false;
    var storedMotion   = true;
    var storedScrollbars = false;
    try {
      storedTheme    = localStorage.getItem('curatorr-theme') || root.dataset.theme || 'night';
      storedBrand    = localStorage.getItem('curatorr-brand-theme') || root.dataset.brandTheme || 'curatorr';
      storedCustom   = localStorage.getItem('curatorr-custom-color') || '#8b5cf6';
      storedInvert   = localStorage.getItem('curatorr-sidebar-invert') === '1';
      storedSquare   = localStorage.getItem('curatorr-square-corners') === '1';
      var motionRaw  = localStorage.getItem('curatorr-bg-motion');
      storedMotion   = motionRaw === null ? true : (motionRaw === '1');
      storedScrollbars = localStorage.getItem('curatorr-hide-scrollbars') === '1';
    } catch(e) {}

    // Mode cards
    var modeCards = document.querySelectorAll('#modeCards .cur-mode-card');
    function syncModeCards(mode) {
      modeCards.forEach(function(c) { c.classList.toggle('is-active', c.dataset.mode === mode); });
    }
    syncModeCards(storedTheme);
    modeCards.forEach(function(card) {
      card.addEventListener('click', function() {
        var mode = card.dataset.mode;
        root.dataset.theme = mode;
        try { localStorage.setItem('curatorr-theme', mode); } catch(e) {}
        syncModeCards(mode);
      });
    });

    // Brand theme presets
    var presets = document.querySelectorAll('#themePresets .theme-preset-card');
    var customChip = document.querySelector('[data-custom-chip]');
    var customColorInput = document.getElementById('customThemeColor');
    if (customColorInput && storedCustom) {
      customColorInput.value = storedCustom;
      if (customChip) customChip.style.setProperty('--theme-color', storedCustom);
    }
    function syncPresets(brand) {
      presets.forEach(function(p) { p.classList.toggle('is-active', p.dataset.brandTheme === brand); });
    }
    syncPresets(storedBrand);
    presets.forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        if (e.target === customColorInput) return;
        var brand = btn.dataset.brandTheme;
        if (brand === 'custom') {
          customColorInput && customColorInput.click();
          return;
        }
        root.dataset.brandTheme = brand;
        try { localStorage.setItem('curatorr-brand-theme', brand); } catch(e) {}
        applyBrandTheme(brand, storedCustom);
        syncPresets(brand);
      });
    });
    if (customColorInput) {
      customColorInput.addEventListener('input', function() {
        var hex = customColorInput.value;
        storedCustom = hex;
        if (customChip) customChip.style.setProperty('--theme-color', hex);
        try { localStorage.setItem('curatorr-custom-color', hex); } catch(e) {}
        applyBrandTheme('custom', hex);
        root.dataset.brandTheme = 'custom';
        try { localStorage.setItem('curatorr-brand-theme', 'custom'); } catch(e) {}
        syncPresets('custom');
      });
    }

    // Toggle options
    var chkInvert      = document.getElementById('chkSidebarInvert');
    var chkSquare      = document.getElementById('chkSquareCorners');
    var chkMotion      = document.getElementById('chkBgMotion');
    var chkScrollbars  = document.getElementById('chkHideScrollbars');
    if (chkInvert) chkInvert.checked = storedInvert;
    if (chkSquare) chkSquare.checked = storedSquare;
    if (chkMotion) chkMotion.checked = storedMotion;
    if (chkScrollbars) chkScrollbars.checked = storedScrollbars;

    function saveToggle(key, el, dataAttr, invert) {
      el && el.addEventListener('change', function() {
        var val = el.checked;
        try { localStorage.setItem(key, val ? '1' : '0'); } catch(e) {}
        if (dataAttr) root.dataset[dataAttr] = (invert ? !val : val) ? '1' : '0';
      });
    }
    saveToggle('curatorr-sidebar-invert',   chkInvert,     'sidebarInvert',   false);
    saveToggle('curatorr-square-corners',   chkSquare,     'squareCorners',   false);
    saveToggle('curatorr-bg-motion',        chkMotion,     'bgMotion',        false);
    saveToggle('curatorr-hide-scrollbars',  chkScrollbars, 'hideScrollbars',  false);

    // Apply initial brand theme so custom colours survive page load
    applyBrandTheme(storedBrand, storedCustom);
  })();

  // ── Plex field visibility toggles ──────────────────────────────────────────
  (function() {
    document.querySelectorAll('[data-visibility-toggle]').forEach(function(btn) {
      var inputId = btn.dataset.visibilityToggle;
      var input = inputId ? document.getElementById(inputId) : null;
      var img = btn.querySelector('img');
      if (!input) return;
      btn.addEventListener('click', function() {
        var isHidden = input.type === 'password';
        input.type = isHidden ? 'text' : 'password';
        btn.dataset.visibilityState = isHidden ? 'visible' : 'hidden';
        btn.setAttribute('aria-label', isHidden ? 'Hide value' : 'Show value');
        if (img) img.src = isHidden ? '/icons/view.svg' : '/icons/view-off.svg';
      });
    });
  })();

  // ── Plex auto-fetch actions ─────────────────────────────────────────────────
  (function() {
    var plexButtons = Array.from(document.querySelectorAll('[data-plex-action]'));
    if (!plexButtons.length) return;
    var runPlexAction = function(button) {
      var action = String(button.dataset.plexAction || '').trim().toLowerCase();
      if (action !== 'token' && action !== 'machine') return;
      var form = button.closest('form');
      if (!form) return;
      var targetInput = form.querySelector('[data-plex-field="' + action + '"]');
      if (!targetInput) return;
      button.disabled = true;
      var endpoint = action === 'token' ? '/api/plex/token' : '/api/plex/machine';
      fetch(endpoint)
        .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
        .then(function(res) {
          if (action === 'token') {
            if (!res.ok || res.data.error) throw new Error(res.data.error || 'Failed to fetch Plex token.');
            targetInput.value = String(res.data.token || '').trim();
          } else {
            if (!res.ok) throw new Error(res.data.error || 'Failed to fetch Plex machine.');
            targetInput.value = res.data.machineId || '';
          }
        })
        .catch(function(err) { console.error('[Curatorr] Plex ' + action + ' fetch failed', err); })
        .finally(function() { button.disabled = false; });
    };
    plexButtons.forEach(function(btn) {
      btn.addEventListener('click', function() { runPlexAction(btn); });
    });
  })();

  // ── Plex user role editor ────────────────────────────────────────────────
  (function() {
    var fetchBtn = document.getElementById('fetchPlexUsersBtn');
    var saveBtn = document.getElementById('savePlexRolesBtn');
    var usersBody = document.getElementById('plexUsersBody');
    var note = document.getElementById('plexUsersNote');
    var usersTabBtn = document.querySelector('.settings-tab-btn[data-tab="users"]');
    if (!fetchBtn || !saveBtn || !usersBody || !note) return;
    var usersLoaded = false;

    function formatLoginTimestamp(value) {
      if (!value) return '—';
      var date = new Date(value);
      if (Number.isNaN(date.getTime())) return '—';
      try {
        return date.toLocaleString(undefined, { dateStyle: 'medium', timeStyle: 'short' });
      } catch (err) {
        return date.toLocaleString();
      }
    }

    function roleOptions(selected) {
      var current = String(selected || 'user').toLowerCase();
      return [
        ['guest', 'Guest'],
        ['user', 'User'],
        ['power-user', 'Power user'],
        ['co-admin', 'Co-admin'],
        ['admin', 'Admin'],
        ['disabled', 'Disabled'],
      ].map(function(entry) {
        return '<option value="' + entry[0] + '"' + (current === entry[0] ? ' selected' : '') + '>' + entry[1] + '</option>';
      }).join('');
    }

    function escapeHtml(value) {
      return String(value == null ? '' : value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    var userSort = { key: 'name', dir: 'asc' };
    var sortHeaders = Array.from(document.querySelectorAll('.settings-users-head-cell[data-sort-key]'));
    function updateUserSortIndicators() {
      sortHeaders.forEach(function(header) {
        var key = header.dataset.sortKey;
        var isActive = key === userSort.key;
        if (isActive) {
          header.dataset.sortDir = userSort.dir;
          header.setAttribute('aria-sort', userSort.dir === 'asc' ? 'ascending' : 'descending');
        } else {
          header.dataset.sortDir = '';
          header.setAttribute('aria-sort', 'none');
        }
      });
    }

    function sortUserRows() {
      var rows = Array.from(usersBody.querySelectorAll('.settings-users-row'));
      var key = userSort.key;
      var isNumeric = key === 'plex' || key === 'curatorr';
      rows.sort(function(a, b) {
        if (isNumeric) {
          var av = Number(a.dataset[key] || 0);
          var bv = Number(b.dataset[key] || 0);
          if (av === bv) return 0;
          return userSort.dir === 'asc' ? av - bv : bv - av;
        }
        var as = String(a.dataset[key] || '');
        var bs = String(b.dataset[key] || '');
        return userSort.dir === 'asc'
          ? as.localeCompare(bs, undefined, { numeric: true, sensitivity: 'base' })
          : bs.localeCompare(as, undefined, { numeric: true, sensitivity: 'base' });
      });
      rows.forEach(function(row) { usersBody.appendChild(row); });
      updateUserSortIndicators();
    }

    sortHeaders.forEach(function(header) {
      var key = header.dataset.sortKey;
      if (!key) return;
      header.addEventListener('click', function() {
        if (userSort.key === key) userSort.dir = userSort.dir === 'asc' ? 'desc' : 'asc';
        else {
          userSort.key = key;
          userSort.dir = (key === 'plex' || key === 'curatorr') ? 'desc' : 'asc';
        }
        sortUserRows();
      });
      header.addEventListener('keydown', function(event) {
        if (event.key !== 'Enter' && event.key !== ' ') return;
        event.preventDefault();
        header.click();
      });
    });
    updateUserSortIndicators();

    function renderUsers(users) {
      usersBody.innerHTML = '';
      users.forEach(function(user) {
        var row = document.createElement('div');
        row.className = 'settings-users-row';
        row.dataset.identifier = user.identifier || '';
        row.dataset.name = String(user.name || user.username || 'Plex User').toLowerCase();
        row.dataset.role = String(user.role || 'user').toLowerCase();
        row.dataset.plex = String(user.lastPlexSeen ? Date.parse(user.lastPlexSeen) || 0 : 0);
        row.dataset.curatorr = String(user.lastCuratorrLogin ? Date.parse(user.lastCuratorrLogin) || 0 : 0);
        var safeName = escapeHtml(user.name || 'Plex User');
        var safeLastPlexSeen = escapeHtml(user.lastPlexSeen || '');
        var safeLastCuratorrLogin = escapeHtml(user.lastCuratorrLogin || '');
        row.innerHTML =
          '<div class="settings-users-name">' + safeName + '</div>' +
          '<div class="settings-users-login" title="' + safeLastPlexSeen + '">' + escapeHtml(formatLoginTimestamp(user.lastPlexSeen)) + '</div>' +
          '<div class="settings-users-login" title="' + safeLastCuratorrLogin + '">' + escapeHtml(formatLoginTimestamp(user.lastCuratorrLogin)) + '</div>' +
          '<div class="settings-users-role">' +
            '<select ' + (user.locked ? 'disabled' : '') + '>' + roleOptions(user.role || 'user') + '</select>' +
            (user.locked ? '<span class="settings-users-locked">Owner</span>' : '') +
          '</div>';
        usersBody.appendChild(row);
      });
      sortUserRows();
    }

    function renderEmpty(message) {
      usersBody.innerHTML = '';
      var row = document.createElement('div');
      row.className = 'settings-users-row';
      row.innerHTML =
        '<div class="settings-users-login">No Plex users found.</div>' +
        '<div class="settings-users-login">—</div>' +
        '<div class="settings-users-login">—</div>' +
        '<div class="settings-users-login">' + (message || '—') + '</div>';
      usersBody.appendChild(row);
    }

    async function fetchUsers() {
      usersLoaded = true;
      fetchBtn.disabled = true;
      note.textContent = 'Fetching Plex users...';
      try {
        var res = await fetch('/settings/plex-users', { headers: { Accept: 'application/json' } });
        var data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed to fetch users.');
        var users = Array.isArray(data.users) ? data.users : [];
        if (users.length) {
          renderUsers(users);
          saveBtn.disabled = false;
          note.textContent = 'Update roles and hit save.';
        } else {
          renderEmpty();
          saveBtn.disabled = true;
          note.textContent = 'No Plex users returned.';
        }
      } catch (err) {
        renderEmpty('Fetch failed');
        saveBtn.disabled = true;
        note.textContent = err.message || 'Failed to fetch users.';
      } finally {
        fetchBtn.disabled = false;
      }
    }

    async function saveRoles() {
      var rows = Array.from(usersBody.querySelectorAll('.settings-users-row[data-identifier]'));
      var roles = rows.map(function(row) {
        var select = row.querySelector('select');
        return {
          identifier: row.dataset.identifier || '',
          role: select ? select.value : 'user',
        };
      });
      saveBtn.disabled = true;
      note.textContent = 'Saving roles...';
      try {
        var res = await fetch('/settings/roles', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': '<%= csrfToken %>',
            Accept: 'application/json'
          },
          body: JSON.stringify({ roles: roles })
        });
        var data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed to save roles.');
        note.textContent = 'Roles saved.';
      } catch (err) {
        note.textContent = err.message || 'Failed to save roles.';
      } finally {
        saveBtn.disabled = false;
      }
    }

    fetchBtn.addEventListener('click', fetchUsers);
    saveBtn.addEventListener('click', saveRoles);
    usersTabBtn && usersTabBtn.addEventListener('click', function() {
      if (!usersLoaded) fetchUsers();
    });
    if (usersTabBtn && usersTabBtn.classList.contains('is-active')) fetchUsers();
  })();
  </script>
</body>
</html>
